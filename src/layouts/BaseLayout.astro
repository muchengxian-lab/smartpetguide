---
interface Props {
  title: string;
  description: string;
  type?: "article" | "product" | "website";
  image?: string;
  publishDate?: string;
  modifiedDate?: string;
  schema?: string;
}

const {
  title,
  description,
  type = "website",
  image = "/images/og-default.svg",
  publishDate,
  modifiedDate,
  schema,
} = Astro.props;

const fullTitle = title.includes("SmartPetGuide")
  ? title
  : `${title} | SmartPetGuide`;

const ogImage = image.startsWith("http")
  ? image
  : new URL(image, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <title>{fullTitle}</title>

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="SmartPetGuide" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="canonical" href={Astro.url.href.replace(/\/$/, "")} />

    {publishDate && (
      <meta property="article:published_time" content={publishDate} />
    )}
    {modifiedDate && (
      <meta property="article:modified_time" content={modifiedDate} />
    )}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="p:domain_verify" content="a5b6492f32e0327f24c9c713bb4032e3"/>
    <link rel="alternate" type="application/rss+xml" title="SmartPetGuide" href="/rss.xml" />

    {schema && <script type="application/ld+json" set:html={schema} />}

    {type === "article" && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        description: description,
        image: ogImage,
        ...(publishDate && { datePublished: publishDate }),
        ...(modifiedDate && { dateModified: modifiedDate }),
        author: { "@type": "Person", name: "SmartPetGuide Team", url: "https://smartpetguide.net/about/", sameAs: ["https://medium.com/@muchengxian", "https://www.pinterest.com/muchengxian/"] },
        publisher: { "@type": "Organization", name: "SmartPetGuide", url: "https://smartpetguide.net/", sameAs: ["https://www.pinterest.com/muchengxian/", "https://medium.com/@muchengxian", "https://flipboard.com/@755g287"] },
        mainEntityOfPage: { "@type": "WebPage", "@id": (Astro.url?.href || "https://smartpetguide.net/").replace(/\/$/, "") },
      })} />
    )}

    <!-- Google Fonts: Fraunces (display) + Atkinson Hyperlegible (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,700;1,9..144,300&display=swap" rel="stylesheet" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DKYRD8PSCT"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-DKYRD8PSCT');
    </script>
  </head>
  <body class="bg-cream font-body text-bark antialiased selection:bg-honey/30">
    <!-- Subtle grain texture overlay -->
    <div class="pointer-events-none fixed inset-0 z-[-1] opacity-[0.03]" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <filter id="noise">
          <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
        </filter>
        <rect width="100%" height="100%" filter="url(#noise)"/>
      </svg>
    </div>

    <header class="sticky top-0 z-50 border-b border-sage-dark/30 bg-cream/95 backdrop-blur-sm">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
        <a href="/" class="group flex items-center gap-2">
          <span class="font-display text-2xl font-bold tracking-tight text-forest">
            Smart<span class="text-honey">Pet</span>Guide
          </span>
        </a>
        <div class="hidden items-center gap-8 text-[15px] font-medium md:flex">
          <a href="/best/" class="text-bark-muted decoration-honey/40 underline-offset-4 transition-colors hover:text-forest">Best Picks</a>
          <a href="/reviews/" class="text-bark-muted decoration-honey/40 underline-offset-4 transition-colors hover:text-forest">Reviews</a>
          <a href="/compare/" class="text-bark-muted decoration-honey/40 underline-offset-4 transition-colors hover:text-forest">Compare</a>
          <a href="/guides/" class="text-bark-muted decoration-honey/40 underline-offset-4 transition-colors hover:text-forest">Guides</a>
          <a href="/breed/" class="text-bark-muted decoration-honey/40 underline-offset-4 transition-colors hover:text-forest">Breeds</a>
          <a href="/about/" class="text-bark-muted decoration-honey/40 underline-offset-4 transition-colors hover:text-forest">About</a>
        </div>
        <!-- Mobile menu trigger -->
        <button id="mobile-menu-btn" class="flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium text-forest md:hidden" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg id="menu-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 5h14M3 10h14M3 15h14"/>
          </svg>
          <svg id="close-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
            <path d="M5 5l10 10M15 5L5 15"/>
          </svg>
          <span id="menu-label">Menu</span>
        </button>
      </nav>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden border-t border-sage-dark/30 bg-cream md:hidden" role="navigation" aria-label="Mobile navigation">
        <div class="mx-auto max-w-6xl px-5 py-4 flex flex-col gap-3">
          <a href="/best/" class="block rounded-lg px-3 py-2 text-[15px] font-medium text-bark-muted hover:bg-sage/40 hover:text-forest">Best Picks</a>
          <a href="/reviews/" class="block rounded-lg px-3 py-2 text-[15px] font-medium text-bark-muted hover:bg-sage/40 hover:text-forest">Reviews</a>
          <a href="/compare/" class="block rounded-lg px-3 py-2 text-[15px] font-medium text-bark-muted hover:bg-sage/40 hover:text-forest">Compare</a>
          <a href="/guides/" class="block rounded-lg px-3 py-2 text-[15px] font-medium text-bark-muted hover:bg-sage/40 hover:text-forest">Guides</a>
          <a href="/breed/" class="block rounded-lg px-3 py-2 text-[15px] font-medium text-bark-muted hover:bg-sage/40 hover:text-forest">Breeds</a>
          <a href="/about/" class="block rounded-lg px-3 py-2 text-[15px] font-medium text-bark-muted hover:bg-sage/40 hover:text-forest">About</a>
        </div>
      </div>
    </header>

    <script>
      (function() {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        const icon = document.getElementById('menu-icon');
        const closeIcon = document.getElementById('close-icon');
        const label = document.getElementById('menu-label');
        if (!btn || !menu) return;
        btn.addEventListener('click', () => {
          const open = menu.classList.toggle('hidden');
          btn.setAttribute('aria-expanded', String(!open));
          icon.classList.toggle('hidden', !open);
          closeIcon.classList.toggle('hidden', open);
          label.textContent = open ? 'Menu' : 'Close';
        });
      })();
    </script>

    <main class="mx-auto max-w-6xl px-5 py-12">
      <slot />
    </main>

    <footer class="mt-20 border-t border-sage-dark/30 bg-forest text-white">
      <div class="mx-auto max-w-6xl px-5 py-16">
        <div class="grid gap-12 md:grid-cols-3">
          <div>
            <p class="font-display text-xl font-bold">
              Smart<span class="text-honey-light">Pet</span>Guide
            </p>
            <p class="mt-3 text-sm leading-relaxed text-white/70">
              Honest, research-backed reviews of the best smart pet devices. Based on verified owner data and real-world experience.
            </p>
          </div>
          <div>
            <p class="font-semibold text-white/90">Browse</p>
            <ul class="mt-3 space-y-2 text-sm text-white/70">
              <li><a href="/best/automatic-cat-feeders/" class="transition-colors hover:text-honey-light">Automatic Feeders</a></li>
              <li><a href="/best/self-cleaning-litter-boxes/" class="transition-colors hover:text-honey-light">Self-Cleaning Litter Boxes</a></li>
              <li><a href="/best/smart-pet-water-fountains/" class="transition-colors hover:text-honey-light">Smart Water Fountains</a></li>
              <li><a href="/best/pet-cameras/" class="transition-colors hover:text-honey-light">Pet Cameras</a></li>
              <li><a href="/best/gps-trackers-no-monthly-fee/" class="transition-colors hover:text-honey-light">GPS Trackers</a></li>
            </ul>
          </div>
          <div>
            <p class="font-semibold text-white/90">Info</p>
            <ul class="mt-3 space-y-2 text-sm text-white/70">
              <li><a href="/about/" class="transition-colors hover:text-honey-light">About Us</a></li>
              <li><a href="/privacy/" class="transition-colors hover:text-honey-light">Privacy Policy</a></li>
              <li><a href="/affiliate-disclosure/" class="transition-colors hover:text-honey-light">Affiliate Disclosure</a></li>
              <li><a href="/how-we-research/" class="transition-colors hover:text-honey-light">How We Research</a></li>
              <li><a href="/products-we-dont-recommend/" class="transition-colors hover:text-honey-light">Products We Don't Recommend</a></li>
              <li><a href="/rss.xml" class="transition-colors hover:text-honey-light">RSS Feed</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-12 border-t border-white/10 pt-8 text-center text-xs text-white/50">
          <p>All content researched and written by the SmartPetGuide editorial team. Published {new Date().getFullYear()}.</p>
          <p class="mt-1">As an Amazon Associate, SmartPetGuide earns from qualifying purchases. &copy; {new Date().getFullYear()} SmartPetGuide. All rights reserved.</p>
          <p class="mt-2 text-white/40">This site provides product research and recommendations, not veterinary advice. Consult your veterinarian for pet health concerns.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
