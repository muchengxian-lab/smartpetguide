---
const { items }: { items: string[] } = Astro.props;
if (!items || items.length === 0) return;
---

<div class="mt-8 rounded-2xl border border-sage-dark/30 bg-sage-light/40 p-6 md:p-7">
  <p class="text-sm font-semibold uppercase tracking-wider text-forest/70">Key Takeaways</p>
  <ul class="mt-3 space-y-2">
    {items.map((item) => (
      <li class="flex gap-2.5 text-[15px] leading-relaxed text-bark">
        <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-honey"></span>
        {item}
      </li>
    ))}
  </ul>
</div>
