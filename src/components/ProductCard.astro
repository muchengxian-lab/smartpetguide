---
interface Product {
  id: string;
  name: string;
  brand: string;
  price: number;
  amazonUrl: string;
  imageUrl: string;
  rating: number;
  reviewCount: number;
  features: string[];
  pros: string[];
  cons: string[];
  bestFor: string[];
  category: string;
}

const { product, rank }: { product: Product; rank?: number } = Astro.props;
const stars = Math.round(product.rating);
---

<div class="group relative overflow-hidden rounded-2xl border border-sage-dark/40 bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5">
  <!-- Rank badge -->
  {rank && (
    <div class="absolute -left-0.5 -top-0.5 flex h-9 w-9 items-center justify-center rounded-br-xl bg-forest text-sm font-bold text-white shadow-sm">
      {rank}
    </div>
  )}

  <div class="flex flex-col gap-5 sm:flex-row">
    <!-- Image placeholder -->
    <div class="flex-shrink-0">
      <div class="flex h-44 w-44 items-center justify-center rounded-xl bg-sage/60">
        {product.imageUrl ? (
          <img src={product.imageUrl} alt={product.name} class="h-full w-full rounded-xl object-cover" loading="lazy" onerror="this.style.display='none'" />
        ) : (
          <div class="text-center text-sm text-bark-muted/50">
            <svg class="mx-auto mb-1 h-10 w-10 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            <span class="text-xs">Photo</span>
          </div>
        )}
      </div>
    </div>

    <div class="flex-1">
      <div class="flex items-start justify-between gap-2">
        <div>
          <h3 class="font-display text-xl font-semibold text-forest">{product.name}</h3>
          <p class="text-sm text-bark-muted">by {product.brand}</p>
        </div>
        <div class="shrink-0 text-right">
          <p class="font-display text-2xl font-bold text-forest">${product.price}</p>
          <div class="flex items-center justify-end gap-1 text-honey">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg key={i} class={`h-3.5 w-3.5 ${i < stars ? "text-honey" : "text-sage-dark/50"}`} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
            <span class="ml-1 text-xs text-bark-muted">({product.reviewCount.toLocaleString()})</span>
          </div>
        </div>
      </div>

      <p class="mt-3 text-sm text-bark-muted leading-relaxed">
        <span class="font-semibold text-bark">Best for:</span> {product.bestFor.join(", ")}
      </p>

      <a
        href={product.amazonUrl}
        target="_blank"
        rel="nofollow sponsored noopener"
        class="mt-4 inline-flex items-center gap-1.5 rounded-xl bg-honey px-6 py-2.5 text-[15px] font-bold text-white shadow-sm transition-all hover:bg-honey-dark hover:shadow-md active:scale-[0.98]"
      >
        View on Amazon
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</div>
