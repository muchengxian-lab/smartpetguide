---
interface Product {
  id: string;
  name: string;
  brand: string;
  price: number;
  amazonUrl: string;
  imageUrl: string;
  rating: number;
  reviewCount: number;
  features: string[];
  pros: string[];
  cons: string[];
  bestFor: string[];
  category: string;
}

const { product, rank }: { product: Product; rank?: number } = Astro.props;
const stars = Math.round(product.rating);
---

<div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
  {rank && (
    <span class="mb-2 inline-block rounded-full bg-primary px-3 py-1 text-xs font-bold text-white">
      #{rank}
    </span>
  )}
  <div class="flex flex-col gap-4 sm:flex-row">
    <div class="h-48 w-48 flex-shrink-0 rounded-lg bg-gray-100 flex items-center justify-center text-gray-400 text-sm">
      {product.imageUrl ? (
        <img src={product.imageUrl} alt={product.name} class="h-full w-full rounded-lg object-cover" />
      ) : (
        <span>[Product Image]</span>
      )}
    </div>
    <div class="flex-1">
      <h3 class="text-lg font-bold text-gray-900">{product.name}</h3>
      <p class="text-sm text-gray-500">by {product.brand}</p>
      <div class="mt-2 flex items-center gap-2">
        <span class="text-accent text-lg font-bold">{"★".repeat(stars)}{"☆".repeat(5 - stars)}</span>
        <span class="text-sm text-gray-500">({product.reviewCount.toLocaleString()} reviews)</span>
      </div>
      <p class="mt-2 text-2xl font-bold text-primary">${product.price}</p>
      <p class="mt-2 text-sm text-gray-600">
        <strong>Best for:</strong> {product.bestFor.join(", ")}
      </p>
      <a
        href={product.amazonUrl}
        target="_blank"
        rel="nofollow sponsored noopener"
        class="mt-4 inline-block rounded-lg bg-accent px-6 py-2.5 font-semibold text-white transition-colors hover:bg-accent-dark"
      >
        Check Price on Amazon
      </a>
    </div>
  </div>
</div>
