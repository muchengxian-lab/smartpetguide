---
interface Product {
  name: string;
  brand: string;
  price: number;
  rating: number;
  features: string[];
  bestFor: string[];
}

interface Props { products: Product[]; dimensionLabels?: string[]; }

const { products, dimensionLabels = ["Price", "Rating", "App", "Camera", "Capacity", "Best For"] } = Astro.props;
---

<div class="overflow-x-auto rounded-2xl border border-sage-dark/30 shadow-sm">
  <table class="w-full text-left text-sm">
    <thead>
      <tr class="bg-sage/60">
        <th class="px-5 py-3.5 font-semibold text-forest">Product</th>
        {dimensionLabels.map((label) => (
          <th class="px-5 py-3.5 font-semibold text-forest whitespace-nowrap">{label}</th>
        ))}
      </tr>
    </thead>
    <tbody class="divide-y divide-sage-dark/20">
      {products.map((p, idx) => (
        <tr class="bg-white transition-colors hover:bg-sage-light/50">
          <td class="px-5 py-4">
            <span class="font-semibold text-bark">{p.name}</span>
            <span class="block text-xs text-bark-muted">{p.brand}</span>
          </td>
          <td class="px-5 py-4 font-display font-semibold text-forest">${p.price}</td>
          <td class="px-5 py-4">
            <span class="text-honey">
              {"★".repeat(Math.round(p.rating))}
              <span class="text-sage-dark/50">{"★".repeat(5 - Math.round(p.rating))}</span>
            </span>
          </td>
          <td class="px-5 py-4">
            {p.features.some(f => f.toLowerCase().includes("app")) ? (
              <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-sage"><svg class="h-3 w-3 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
            ) : (
              <span class="text-bark-muted/30">—</span>
            )}
          </td>
          <td class="px-5 py-4">
            {p.features.some(f => f.toLowerCase().includes("camera") || f.toLowerCase().includes("1080p")) ? (
              <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-sage"><svg class="h-3 w-3 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
            ) : (
              <span class="text-bark-muted/30">—</span>
            )}
          </td>
          <td class="whitespace-nowrap px-5 py-4 text-xs text-bark-muted">
            {p.features.find(f => f.toLowerCase().includes("capacity") || f.toLowerCase().includes("l") || f.toLowerCase().includes("day")) || "—"}
          </td>
          <td class="px-5 py-4 text-xs text-bark-muted leading-relaxed">{p.bestFor.slice(0, 2).join(", ")}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
