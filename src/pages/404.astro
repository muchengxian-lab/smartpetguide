---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="py-20 text-center">
    <h1 class="text-6xl font-extrabold text-gray-200">404</h1>
    <p class="mt-4 text-lg text-gray-500">This page doesn't exist. But your pet still loves you.</p>
    <a href="/" class="mt-6 inline-block rounded-lg bg-primary px-6 py-3 font-semibold text-white hover:bg-primary-dark">Back to Home</a>
  </div>
</BaseLayout>
