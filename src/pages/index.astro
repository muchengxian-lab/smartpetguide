---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import products from "../data/products.json";

const topPicks = [
  products.litterBoxes[0],
  products.feeders[1],
  products.waterFountains[0],
  products.gpsTrackers[0],
];

const categories = [
  { title: "Automatic Feeders", href: "/best/automatic-cat-feeders/", desc: "Never miss a mealtime — app-controlled feeding on your schedule.", count: products.feeders.length, icon: "bowl" },
  { title: "Self-Cleaning Litter Boxes", href: "/best/self-cleaning-litter-boxes/", desc: "Say goodbye to scooping — automatic boxes that do the dirty work.", count: products.litterBoxes.length, icon: "box" },
  { title: "Smart Water Fountains", href: "/best/smart-pet-water-fountains/", desc: "Encourage hydration with filtered, flowing water your pet will love.", count: products.waterFountains.length, icon: "droplet" },
  { title: "Pet Cameras", href: "/best/pet-cameras/", desc: "Check in, toss treats, and talk to your pet from anywhere.", count: products.cameras.length, icon: "camera" },
  { title: "GPS Trackers", href: "/best/gps-trackers-no-monthly-fee/", desc: "Know where your pet is at all times with real-time GPS tracking.", count: products.gpsTrackers.length, icon: "map" },
  { title: "Buying Guides", href: "/guides/", desc: "Not sure where to start? Our comprehensive guides walk you through it.", count: "5+", icon: "book" },
];
---

<BaseLayout
  title="SmartPetGuide — Best Smart Pet Devices, Honestly Reviewed"
  description="Research-backed reviews of the best automatic pet feeders, self-cleaning litter boxes, smart fountains, pet cameras, and GPS trackers. Based on verified owner data and real-world analysis."
>
  <!-- Hero -->
  <section class="pb-12 pt-4 md:pb-20 md:pt-8">
    <div class="mx-auto max-w-3xl text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-sage-dark/30 bg-white px-4 py-1.5 text-sm font-medium text-bark-muted">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-honey opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-honey"></span>
        </span>
        Updated for 2026
      </div>
      <h1 class="font-display text-4xl font-bold leading-[1.15] tracking-tight text-forest md:text-6xl">
        Smart Pet Devices,<br/><span class="text-honey">Honest Reviews</span>
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-bark-muted md:text-xl">
        We analyze thousands of verified owner reviews and real Amazon data to find the best pet tech.
        No fluff, no fake reviews — just honest recommendations based on evidence.
      </p>
    </div>
  </section>

  <!-- Social Proof Bar -->
  <section class="pb-8">
    <div class="mx-auto max-w-3xl">
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
        <div class="rounded-xl border border-sage-dark/30 bg-white px-4 py-3 text-center">
          <p class="font-display text-2xl font-bold text-forest">112</p>
          <p class="text-xs text-bark-muted">Research-Backed Pages</p>
        </div>
        <div class="rounded-xl border border-sage-dark/30 bg-white px-4 py-3 text-center">
          <p class="font-display text-2xl font-bold text-forest">26</p>
          <p class="text-xs text-bark-muted">Products Analyzed</p>
        </div>
        <div class="rounded-xl border border-sage-dark/30 bg-white px-4 py-3 text-center">
          <p class="font-display text-2xl font-bold text-forest">85K+</p>
          <p class="text-xs text-bark-muted">Owner Reviews Analyzed</p>
        </div>
        <div class="rounded-xl border border-sage-dark/30 bg-white px-4 py-3 text-center">
          <p class="font-display text-2xl font-bold text-forest">6</p>
          <p class="text-xs text-bark-muted">Categories Covered</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Guides -->
  <section class="pb-4">
    <div class="mx-auto max-w-3xl">
      <div class="mb-4 flex items-center gap-3">
        <span class="h-0.5 w-8 rounded-full bg-honey"></span>
        <h2 class="font-display text-xl font-bold text-forest">Latest Research</h2>
      </div>
      <div class="grid gap-2 sm:grid-cols-2">
        <a href="/guides/robot-vacuum-vs-stick-vacuum-pet-hair/" class="rounded-lg border border-sage-dark/20 bg-white px-4 py-2.5 text-sm text-forest transition-colors hover:border-honey/40 hover:text-honey">Robot vs Stick Vacuum for Pet Hair</a>
        <a href="/guides/best-robot-vacuum-golden-retriever-shedding/" class="rounded-lg border border-sage-dark/20 bg-white px-4 py-2.5 text-sm text-forest transition-colors hover:border-honey/40 hover:text-honey">Best Robot Vacuum for Golden Retriever Shedding</a>
        <a href="/guides/best-robot-vacuum-cat-litter-tracking/" class="rounded-lg border border-sage-dark/20 bg-white px-4 py-2.5 text-sm text-forest transition-colors hover:border-honey/40 hover:text-honey">Robot Vacuums That Handle Cat Litter</a>
        <a href="/guides/cat-breaking-into-automatic-feeder/" class="rounded-lg border border-sage-dark/20 bg-white px-4 py-2.5 text-sm text-forest transition-colors hover:border-honey/40 hover:text-honey">Stop Your Cat Breaking Into the Feeder</a>
        <a href="/guides/automatic-feeder-wifi-keeps-disconnecting/" class="rounded-lg border border-sage-dark/20 bg-white px-4 py-2.5 text-sm text-forest transition-colors hover:border-honey/40 hover:text-honey">Fix Feeder WiFi Disconnecting</a>
        <a href="/guides/cat-wont-drink-from-water-fountain/" class="rounded-lg border border-sage-dark/20 bg-white px-4 py-2.5 text-sm text-forest transition-colors hover:border-honey/40 hover:text-honey">Cat Won't Drink From Fountain? 8 Fixes</a>
        <a href="/guides/stop-automatic-feeder-from-jamming/" class="rounded-lg border border-sage-dark/20 bg-white px-4 py-2.5 text-sm text-forest transition-colors hover:border-honey/40 hover:text-honey">Stop Your Feeder From Jamming</a>
        <a href="/guides/introduce-cat-to-automatic-litter-box/" class="rounded-lg border border-sage-dark/20 bg-white px-4 py-2.5 text-sm text-forest transition-colors hover:border-honey/40 hover:text-honey">Introduce Cat to Automatic Litter Box</a>
      </div>
      <p class="mt-3 text-center">
        <a href="/guides/" class="text-sm font-medium text-honey underline decoration-honey/30 underline-offset-2 hover:text-honey-dark">See all guides →</a>
      </p>
    </div>
  </section>

  <!-- Top Picks -->
  <section>
    <div class="mb-6 flex items-center gap-3">
      <span class="h-0.5 w-8 rounded-full bg-honey"></span>
      <h2 class="font-display text-2xl font-bold text-forest">Editor's Picks</h2>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {topPicks.map((product, i) => (
        <ProductCard product={product} rank={i + 1} />
      ))}
    </div>
  </section>

  <!-- Category Grid -->
  <section class="mt-20">
    <div class="mb-6 flex items-center gap-3">
      <span class="h-0.5 w-8 rounded-full bg-honey"></span>
      <h2 class="font-display text-2xl font-bold text-forest">Browse by Category</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((cat) => (
        <a href={cat.href} class="group rounded-2xl border border-sage-dark/30 bg-white p-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5">
          <p class="font-display text-lg font-semibold text-forest transition-colors group-hover:text-honey">{cat.title}</p>
          <p class="mt-2 text-sm leading-relaxed text-bark-muted">{cat.desc}</p>
          <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-forest/60">{cat.count} reviews</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Organization Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "SmartPetGuide",
    url: "https://smartpetguide.net/",
    description: "Research-backed reviews of the best smart pet devices. Based on verified owner data and real-world analysis.",
    foundingDate: "2026",
    sameAs: [
      "https://www.pinterest.com/muchengxian/",
      "https://medium.com/@muchengxian",
      "https://flipboard.com/@755g287",
      "https://www.wikidata.org/wiki/Q140290653",
    ],
  })} />

  <!-- Trust bar -->
  <section class="mt-20 rounded-2xl border border-sage-dark/30 bg-white px-8 py-10 text-center">
    <p class="font-display text-xl font-semibold text-forest">Why Trust Our Reviews?</p>
    <div class="mt-6 grid gap-6 sm:grid-cols-3">
      <div>
        <p class="font-display text-3xl font-bold text-honey">500+</p>
        <p class="mt-1 text-sm text-bark-muted">Verified owner reviews analyzed</p>
      </div>
      <div>
        <p class="font-display text-3xl font-bold text-honey">26</p>
        <p class="mt-1 text-sm text-bark-muted">Products researched & compared</p>
      </div>
      <div>
        <p class="font-display text-3xl font-bold text-honey">0</p>
        <p class="mt-1 text-sm text-bark-muted">Sponsored placements</p>
      </div>
    </div>
  </section>
</BaseLayout>
