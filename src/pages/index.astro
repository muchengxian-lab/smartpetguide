---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import products from "../data/products.json";

const topPicks = [
  products.litterBoxes[0],
  products.feeders[1],
  products.waterFountains[0],
  products.gpsTrackers[0],
];

const categories = [
  { title: "Automatic Feeders", href: "/best/automatic-cat-feeders/", desc: "Never miss a mealtime — app-controlled feeding on your schedule.", count: products.feeders.length, icon: "bowl" },
  { title: "Self-Cleaning Litter Boxes", href: "/best/self-cleaning-litter-boxes/", desc: "Say goodbye to scooping — automatic boxes that do the dirty work.", count: products.litterBoxes.length, icon: "box" },
  { title: "Smart Water Fountains", href: "/best/smart-pet-water-fountains/", desc: "Encourage hydration with filtered, flowing water your pet will love.", count: products.waterFountains.length, icon: "droplet" },
  { title: "Pet Cameras", href: "/best/pet-cameras/", desc: "Check in, toss treats, and talk to your pet from anywhere.", count: products.cameras.length, icon: "camera" },
  { title: "GPS Trackers", href: "/best/gps-trackers-no-monthly-fee/", desc: "Know where your pet is at all times with real-time GPS tracking.", count: products.gpsTrackers.length, icon: "map" },
  { title: "Buying Guides", href: "/guides/", desc: "Not sure where to start? Our comprehensive guides walk you through it.", count: "5+", icon: "book" },
];
---

<BaseLayout
  title="SmartPetGuide — Best Smart Pet Devices, Honestly Reviewed"
  description="Research-backed reviews of the best automatic pet feeders, self-cleaning litter boxes, smart fountains, pet cameras, and GPS trackers. Based on verified owner data and real-world analysis."
>
  <!-- Hero -->
  <section class="pb-12 pt-4 md:pb-20 md:pt-8">
    <div class="mx-auto max-w-3xl text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-sage-dark/30 bg-white px-4 py-1.5 text-sm font-medium text-bark-muted">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-honey opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-honey"></span>
        </span>
        Updated for 2026
      </div>
      <h1 class="font-display text-4xl font-bold leading-[1.15] tracking-tight text-forest md:text-6xl">
        Smart Pet Devices,<br/><span class="text-honey">Honest Reviews</span>
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-bark-muted md:text-xl">
        We analyze thousands of verified owner reviews and real Amazon data to find the best pet tech.
        No fluff, no fake reviews — just honest recommendations based on evidence.
      </p>
    </div>
  </section>

  <!-- Top Picks -->
  <section>
    <div class="mb-6 flex items-center gap-3">
      <span class="h-0.5 w-8 rounded-full bg-honey"></span>
      <h2 class="font-display text-2xl font-bold text-forest">Editor's Picks</h2>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {topPicks.map((product, i) => (
        <ProductCard product={product} rank={i + 1} />
      ))}
    </div>
  </section>

  <!-- Category Grid -->
  <section class="mt-20">
    <div class="mb-6 flex items-center gap-3">
      <span class="h-0.5 w-8 rounded-full bg-honey"></span>
      <h2 class="font-display text-2xl font-bold text-forest">Browse by Category</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((cat) => (
        <a href={cat.href} class="group rounded-2xl border border-sage-dark/30 bg-white p-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5">
          <p class="font-display text-lg font-semibold text-forest transition-colors group-hover:text-honey">{cat.title}</p>
          <p class="mt-2 text-sm leading-relaxed text-bark-muted">{cat.desc}</p>
          <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-forest/60">{cat.count} reviews</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Trust bar -->
  <section class="mt-20 rounded-2xl border border-sage-dark/30 bg-white px-8 py-10 text-center">
    <p class="font-display text-xl font-semibold text-forest">Why Trust Our Reviews?</p>
    <div class="mt-6 grid gap-6 sm:grid-cols-3">
      <div>
        <p class="font-display text-3xl font-bold text-honey">500+</p>
        <p class="mt-1 text-sm text-bark-muted">Verified owner reviews analyzed</p>
      </div>
      <div>
        <p class="font-display text-3xl font-bold text-honey">25</p>
        <p class="mt-1 text-sm text-bark-muted">Products researched & compared</p>
      </div>
      <div>
        <p class="font-display text-3xl font-bold text-honey">0</p>
        <p class="mt-1 text-sm text-bark-muted">Sponsored placements</p>
      </div>
    </div>
  </section>
</BaseLayout>
