      { id: "litter-robot-4", name: "Litter-Robot 4", brand: "Whisker", price: 699, rating: 4.5, features: ["Automatic sifting", "App control", "Multi-cat compatible", "Odor control", "Waste drawer indicator", "4 cat capacity"], pros: ["Best-in-class odor control", "Large waste drawer", "Excellent app"], cons: ["Expensive", "Large footprint"], bestFor: ["Multi-cat households", "Owners who want the best"], amazonUrl: "https://www.amazon.com/dp/B0BG4NP272?tag=smartpetgui0a-20", imageUrl: "", reviewCount: 12500, category: "litterBox", weight: 3.6, warranty: "1 year" },
