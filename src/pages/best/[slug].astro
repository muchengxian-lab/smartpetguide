---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";
import FAQ from "../../components/FAQ.astro";
import Takeaways from "../../components/Takeaways.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import products from "../../data/products.json";

// Flat product lookup
const allProductMap = new Map<string, any>();
for (const [, items] of Object.entries(products)) {
  for (const p of items as any[]) allProductMap.set(p.id, p);
}

export function getStaticPaths() {
  return [
    { params: { slug: "self-cleaning-litter-boxes" } },
    { params: { slug: "automatic-cat-feeders" } },
    { params: { slug: "smart-pet-water-fountains" } },
    { params: { slug: "pet-cameras" } },
    { params: { slug: "gps-trackers-no-monthly-fee" } },
    { params: { slug: "pet-cameras-no-subscription" } },
    { params: { slug: "litter-boxes-for-large-cats" } },
    { params: { slug: "stainless-steel-cat-fountains" } },
    { params: { slug: "automatic-feeders-for-2-cats" } },
  ];
}

const categoryMap: Record<string, keyof typeof products> = {
  "self-cleaning-litter-boxes": "litterBoxes",
  "automatic-cat-feeders": "feeders",
  "smart-pet-water-fountains": "waterFountains",
  "pet-cameras": "cameras",
};

// Custom product lists for curated pages
const customLists: Record<string, string[]> = {
  "gps-trackers-no-monthly-fee": ["tractive-gps", "nofee-gps-tracker", "aorkuler-gps"],
  "pet-cameras-no-subscription": ["eufy-pet-cam", "xpai-4k-camera", "honeytour-robot-cam", "furbo-360"],
  "litter-boxes-for-large-cats": ["litter-robot-4", "catlink-young", "petsafe-scoopfree", "elspet-pro"],
  "stainless-steel-cat-fountains": ["pioneer-pet-raindrop", "yeapaw-steel-fountain", "kittyspout-steel"],
  "automatic-feeders-for-2-cats": ["petlibro-granary", "wopet-automatic", "petkit-fresh-element", "dogness-mini"],
};

const slug = Astro.params.slug || "self-cleaning-litter-boxes";
const categoryKey = categoryMap[slug];

const allProducts = categoryKey
  ? products[categoryKey]
  : (customLists[slug] || []).map((id: string) => allProductMap.get(id)).filter(Boolean);

const titleMap: Record<string, { title: string; description: string; faqs: { q: string; a: string }[] }> = {
  "self-cleaning-litter-boxes": {
    title: "5 Best Self-Cleaning Litter Boxes of 2026 — Tested & Reviewed",
    description: "We tested the top automatic litter boxes to find the best for odor control, multi-cat homes, and budget. Litter-Robot vs Leo's Loo vs PetSafe and more.",
    faqs: [
      { q: "Are self-cleaning litter boxes worth it?", a: "Yes, if you value your time and want better odor control. A quality self-cleaning box like the Litter-Robot 4 can reduce scooping to once every 1-2 weeks and significantly cut litter box odors." },
      { q: "How often do you need to empty a self-cleaning litter box?", a: "Most self-cleaning boxes need the waste drawer emptied every 5-7 days for a single cat, or every 2-3 days for multiple cats." },
      { q: "Do self-cleaning litter boxes work with clumping litter?", a: "Yes, almost all self-cleaning litter boxes require clumping litter to function properly. Crystal litter systems like PetSafe ScoopFree are an exception." },
      { q: "Can a self-cleaning litter box scare my cat?", a: "Some cats are initially nervous about the motor noise and movement. Look for models with safety sensors that pause when a cat is near. Gradual introduction helps — leave it unplugged for the first week." },
      { q: "What's the best self-cleaning litter box for multiple cats?", a: "The Litter-Robot 4 handles up to 4 cats and has the largest waste drawer. The CATLINK Young Pro can identify individual cats by weight, which is great for multi-cat health monitoring." },
    ],
  },
  "automatic-cat-feeders": {
    title: "5 Best Automatic Cat Feeders of 2026 — Smart Feeding Solutions",
    description: "Compare the best automatic pet feeders with app control, cameras, and portion management. WOPET vs Petlibro vs DOGNESS vs PETKIT — which is right for you?",
    faqs: [
      { q: "Are automatic pet feeders worth it?", a: "Absolutely — if you work long hours, travel occasionally, or want consistent portion control for your pet. An automatic feeder ensures your pet eats on schedule even when you're not home." },
      { q: "How long can an automatic feeder last without refilling?", a: "A 4-6L capacity feeder can feed one cat for 15-25 days. Smaller 2-3L feeders last about 7-10 days for a single pet." },
      { q: "Do I need a feeder with a camera?", a: "A camera is worth the extra cost if you want peace of mind — you can confirm your pet actually ate. The Petlibro Granary combines both at a reasonable price." },
      { q: "What happens if the power goes out?", a: "Most quality feeders have dual power (AC + battery backup). The WOPET and Petlibro both include battery backup options so your pet won't miss a meal." },
      { q: "Can automatic feeders handle wet food?", a: "No — almost all dry-food-only. For wet food, look for feeders with ice pack compartments or timed lid-opening designs (a separate niche category)." },
    ],
  },
  "smart-pet-water-fountains": {
    title: "5 Best Smart Pet Water Fountains of 2026 — Tested & Reviewed",
    description: "We tested the top smart water fountains for cats and dogs. From the budget Pioneer Pet to the app-controlled Catit PIXI, find the best fountain for your pet.",
    faqs: [
      { q: "Are smart water fountains really better than a bowl?", a: "Yes — moving water stays fresher, filters remove impurities, and pets instinctively prefer running water. Vets recommend fountains to increase water intake, which helps prevent urinary and kidney issues." },
      { q: "How often should I clean a pet water fountain?", a: "Deep clean weekly (dishwasher safe models make this easy). Replace filters every 2-4 weeks. If you notice slime or biofilm sooner, clean it immediately." },
      { q: "Is a smart fountain with an app worth it?", a: "If your cat has a history of urinary issues, the intake tracking on the Catit PIXI can provide valuable health insights. Otherwise, a non-smart fountain like the Pioneer Pet Raindrop does the job just as well." },
      { q: "Which fountain is best for multiple pets?", a: "The Catit PIXI (3L) offers the best capacity for multi-pet homes. Avoid 2L models unless you're fine refilling every other day." },
    ],
  },
  "pet-cameras": {
    title: "5 Best Pet Cameras of 2026 — Treat-Tossing, Monitoring & More",
    description: "We tested the best pet cameras with treat tossing, two-way audio, and smart alerts. Furbo vs Petcube vs budget options — find the right pet cam for your home.",
    faqs: [
      { q: "Are pet cameras worth it?", a: "Yes — if you work outside the home or travel. A pet camera gives peace of mind and treat-tossing models let you interact with your pet remotely. Basic cameras start at $30, but treat-tossing models ($99+) add genuine value for dog owners." },
      { q: "Do pet cameras need a subscription?", a: "Some do for advanced features. Furbo charges $5.99/month for AI alerts and cloud recording. eufy has no subscription (local storage). Most basic live streaming works without a subscription." },
      { q: "Can pet cameras help with separation anxiety?", a: "Many owners report improvement. Being able to see, talk to, and toss treats to your dog during the day helps anxious pets feel connected. However, severe anxiety still requires training." },
      { q: "Which treats work in a treat-tossing camera?", a: "Small, round, dry treats (~1cm diameter). Large or irregular treats jam the mechanism. Furbo sells compatible treats, but most small training treats work in any brand's dispenser." },
    ],
  },
  "gps-trackers-no-monthly-fee": {
    title: "Best GPS Dog Trackers Without Monthly Fee 2026 — No Subscription Picks",
    description: "Tired of subscription fees? We found the best GPS dog trackers with no monthly fees. Compare truly subscription-free trackers from Aorkuler, budget no-fee options, and the best cellular tracker for those okay with a small fee.",
    faqs: [
      { q: "Are there really GPS dog trackers with no monthly fee?", a: "Yes — but they use different technology. Truly no-fee trackers like Aorkuler use radio frequency (RF) instead of cellular networks, limiting range to 3-5 miles. Bluetooth trackers like Apple AirTag have no fees but no real-time GPS. For unlimited-range GPS, cellular trackers like Tractive charge $5-13/month." },
      { q: "What's the range of a no-subscription GPS tracker?", a: "RF-based trackers like Aorkuler have a 3-5 mile range through open terrain. This is perfect for hiking and rural areas but won't help if your dog escapes and runs 10+ miles. For unlimited range, you need a cellular GPS tracker with a subscription." },
      { q: "Can I use an Apple AirTag as a dog GPS tracker?", a: "AirTags can work for dogs in urban/suburban areas because they ping off nearby iPhones (billions of devices). But they are NOT real GPS trackers — they show the last seen location, not live tracking. They're a budget supplement, not a replacement for a dedicated GPS tracker." },
      { q: "Which no-subscription tracker is best for hiking?", a: "The Aorkuler GPS Tracker at $229 is the best choice for off-grid adventures. It works without cell signal, doesn't need a phone, and the handheld controller shows your dog's direction and distance up to 3.5 miles away." },
      { q: "Why do most GPS trackers charge a monthly fee?", a: "Cellular GPS trackers need a SIM card and data plan to transmit your dog's location via cell towers — just like a phone. The subscription covers this cellular data. No-fee trackers skip the cellular network entirely, using radio signals or Bluetooth instead." },
    ],
  },
  "pet-cameras-no-subscription": {
    title: "Best Pet Cameras Without Subscription 2026 — No Monthly Fees",
    description: "Don't want another monthly bill? We found the best pet cameras with no subscription required. Local storage, free AI features, and zero monthly fees — compare eufy, xpai 4K, Honey Tour robot, and more.",
    faqs: [
      { q: "Do all pet cameras require a subscription?", a: "No — many cameras work fine without a subscription. The eufy Pet Camera stores video locally on an SD card, xpai has 64GB built-in storage, and Honey Tour robot has no subscription at all. Even Furbo's basic features (live view, treat tossing) work without paying." },
      { q: "What features do I lose without a subscription?", a: "Typically cloud recording, AI-powered alerts (person/pet detection), and activity summaries require a subscription. But live streaming, two-way audio, treat tossing, and local recording usually work without one. Check each model's free-vs-paid feature list." },
      { q: "Can I use a regular security camera as a pet camera?", a: "Yes — many of the best 'no subscription' pet cameras are actually security cameras that work great for pets. The xpai 4K and eufy Indoor Cam both have pan/tilt, two-way audio, and pet detection — sometimes at half the price of 'pet-specific' cameras." },
      { q: "Which no-subscription camera is best for treat tossing?", a: "The Furbo 360 at $179 allows treat tossing without a subscription (only AI alerts need the $5.99/month plan). For truly zero-fee treat tossing, there are limited options — most treat cameras tie advanced features to subscriptions." },
      { q: "Is local storage better than cloud storage for pet cameras?", a: "For privacy, yes — local SD card storage means your video never leaves your home. For convenience, cloud storage lets you check footage from anywhere. The eufy and xpai both use local storage, making them ideal no-subscription choices." },
    ],
  },
  "litter-boxes-for-large-cats": {
    title: "Best Self-Cleaning Litter Boxes for Large Cats 2026 — Roomy Picks",
    description: "Large cats need bigger litter boxes. We tested the best self-cleaning litter boxes with extra room for Maine Coons, Ragdolls, and other big breeds — plus multi-cat households.",
    faqs: [
      { q: "What size litter box does a large cat need?", a: "A large cat (15+ lbs) needs a litter box at least 22-24 inches long and 18+ inches wide. Standard automatic boxes often have 15-16 inch openings which can be cramped. The Litter-Robot 4 and CATLINK Young Pro have the roomiest interiors we've tested for big cats." },
      { q: "Can Maine Coons use automatic litter boxes?", a: "Yes — but only the largest models. The Litter-Robot 4 has the widest opening (15.75 inches) and internal space of any automatic box we've tested. The CATLINK Young Pro also works well. Avoid compact models like Leo's Loo Too for cats over 15 lbs." },
      { q: "How many litter boxes do I need for multiple large cats?", a: "The rule is N+1 (one more box than cats). For two large cats, you'd want 3 boxes. However, a single Litter-Robot 4 can serve 2-3 cats effectively because it cleans after every use — reducing the need for multiple boxes." },
      { q: "Do large cats need special litter in automatic boxes?", a: "Standard clumping litter works for most large cats in automatic boxes. However, some large cats produce more waste — look for litters with strong clumping action and consider changing the waste drawer liner more frequently." },
    ],
  },
  "stainless-steel-cat-fountains": {
    title: "Best Stainless Steel Cat Water Fountains 2026 — Hygienic & Quiet",
    description: "Stainless steel fountains are more hygienic than plastic — no micro-scratches for bacteria to hide in. We compare the best steel fountains from Pioneer Pet, YEAPAW, KittySpout, and more.",
    faqs: [
      { q: "Why is stainless steel better than plastic for pet fountains?", a: "Plastic develops micro-scratches over time that harbor bacteria, even with regular cleaning. Stainless steel is non-porous, resists bacterial growth, and is naturally more hygienic. It also doesn't leach chemicals and is easier to clean — most steel fountains are dishwasher safe." },
      { q: "Are stainless steel fountains louder than plastic ones?", a: "No — the noise level depends on the pump and water flow design, not the material. The Pioneer Pet Raindrop is one of the quietest fountains available despite being all steel. Pumpless designs like YEAPAW are virtually silent." },
      { q: "How do I clean a stainless steel cat fountain?", a: "Most steel fountains are dishwasher safe (top rack). For daily maintenance, rinse the bowl and refill with fresh water. Deep clean weekly: disassemble, run through dishwasher or hand wash with mild soap, and replace the filter every 2-4 weeks." },
      { q: "Do stainless steel fountains cost more?", a: "Budget steel fountains like Pioneer Pet Raindrop start at $39 — actually cheaper than many plastic smart fountains. Premium steel options like YEAPAW ($93) cost more due to pumpless wireless design. Overall, steel fountains are competitive on price." },
    ],
  },
  "automatic-feeders-for-2-cats": {
    title: "Best Automatic Cat Feeders for 2 Cats 2026 — Dual Feeding Solutions",
    description: "Feeding two cats with one automatic feeder? We found the best options for multi-cat homes — dual trays, large capacity, and portion splitting that actually works.",
    faqs: [
      { q: "Can two cats share one automatic feeder?", a: "Yes — but you need the right setup. Feeders with dual trays (like Petlibro Granary with splitter) let each cat eat from their own bowl. Large-capacity feeders (6L+) can hold enough for two cats for a week. Camera feeders let you confirm both cats actually ate." },
      { q: "How do I stop one cat from eating the other's food?", a: "Microchip-activated feeders are the gold standard but expensive ($150-250). For budget solutions, use a feeder with a splitter tray (Petlibro sells one) placed in different spots, or schedule meals when you're home to supervise. Some feeders let you dispense small portions frequently to prevent food guarding." },
      { q: "What capacity feeder do I need for 2 cats?", a: "For two cats eating 1/2 cup each per day: a 4L feeder lasts about 10-12 days, a 6L feeder lasts 15-18 days. The WOPET 6L at $89 is the best value for dual-cat capacity." },
      { q: "Should I get one feeder or two for my cats?", a: "One large feeder works for most two-cat homes and saves money. Two small feeders are better if your cats eat different foods, need different portion sizes, or tend to fight over food. The Petlibro Granary with splitter is a good middle ground." },
    ],
  },
};

const pageData = titleMap[slug] || titleMap["self-cleaning-litter-boxes"];
const isLitterBox = slug.includes("litter");
---

<BaseLayout title={pageData.title} description={pageData.description} type="article">
  <Breadcrumb crumbs={[{ label: "Best Picks", href: "/best/" }, { label: pageData.title.replace(/^\d+\s/, "") }]} />

  <article>
    <h1 class="font-display text-3xl font-bold leading-tight text-forest md:text-4xl">{pageData.title}</h1>
    <p class="mt-3 text-lg leading-relaxed text-bark-muted">{pageData.description}</p>

    <Takeaways items={[
      `${allProducts.length} products tested and compared`,
      `Top pick: ${allProducts[0]?.name || ""} ($${allProducts[0]?.price || 0})`,
      `Best budget: ${[...allProducts].sort((a: any, b: any) => a.price - b.price)[0]?.name || ""} ($${[...allProducts].sort((a: any, b: any) => a.price - b.price)[0]?.price || 0})`,
      `Best rated: ${[...allProducts].sort((a: any, b: any) => b.rating - a.rating)[0]?.name || ""} (${[...allProducts].sort((a: any, b: any) => b.rating - a.rating)[0]?.rating || 0}★)`,
    ]} />

    <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-1 text-sm text-bark-muted">
      <span>Updated: <time datetime="2026-05-21">May 21, 2026</time></span>
      <span>12 min read</span>
      <span class="rounded-full bg-sage/70 px-2.5 py-0.5 text-xs font-medium text-forest">Advertiser Disclosure</span>
    </div>

    <!-- Quick Comparison Table -->
    <section class="mt-10">
      <h2 class="mb-4 font-display text-xl font-bold text-forest">Quick Comparison</h2>
      <ComparisonTable products={allProducts} />
    </section>

    <!-- Ranked Picks -->
    <section class="mt-12">
      <h2 class="mb-5 font-display text-2xl font-bold text-forest">Our Top Picks</h2>
      <div class="grid gap-5">
        {allProducts.map((p, i) => (
          <div class="rounded-2xl border border-sage-dark/30 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
            <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
              <div class="shrink-0">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-forest text-lg font-bold text-white shadow-sm">
                  {i + 1}
                </div>
              </div>
              <div class="flex-1">
                <div class="flex flex-col gap-4 sm:flex-row">
                  <!-- Product image -->
                  <div class="shrink-0">
                    <img src={p.imageUrl} alt={p.name} class="h-40 w-40 rounded-xl object-cover bg-sage/60" width="160" height="160" loading="lazy" decoding="async" />
                  </div>
                  <div class="flex-1">
                    <h3 class="font-display text-xl font-semibold text-forest">{p.name}</h3>
                    <p class="text-sm text-bark-muted">by {p.brand} &middot; {"★".repeat(Math.round(p.rating))}<span class="text-bark-muted/50">{"★".repeat(5 - Math.round(p.rating))}</span> ({p.reviewCount.toLocaleString()} reviews)</p>
                    <p class="mt-1 font-display text-2xl font-bold text-forest">${p.price}</p>

                    <div class="mt-3 grid gap-4 sm:grid-cols-2">
                      <div>
                        <p class="mb-1.5 text-sm font-semibold text-green-800">What We Like</p>
                        <ul class="space-y-1 text-sm text-green-800/80">
                          {p.pros.map((pro: string) => <li class="flex gap-1.5"><span>+</span> {pro}</li>)}
                        </ul>
                      </div>
                      <div>
                        <p class="mb-1.5 text-sm font-semibold text-rose-dark/80">Watch Out For</p>
                        <ul class="space-y-1 text-sm text-rose-dark/70">
                          {p.cons.map((con: string) => <li class="flex gap-1.5"><span>-</span> {con}</li>)}
                        </ul>
                      </div>
                    </div>

                    <p class="mt-3 text-sm text-bark-muted"><span class="font-semibold text-bark">Best for:</span> {p.bestFor.join(", ")}</p>
                    <a href={p.amazonUrl} target="_blank" rel="nofollow sponsored noopener"
                       class="mt-4 inline-flex items-center gap-2 rounded-xl bg-honey px-6 py-2.5 font-bold text-white shadow-sm transition-all hover:bg-honey-dark hover:shadow-md active:scale-[0.98]">
                      View on Amazon
                      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- How to Choose -->
    <section class="mt-12 rounded-2xl border border-sage-dark/30 bg-sage-light/50 p-6 md:p-8">
      <h2 class="font-display text-xl font-bold text-forest">How to Choose the Right One</h2>
      <div class="mt-4 space-y-3">
        <p class="text-bark-muted leading-relaxed">When shopping for {isLitterBox ? "a self-cleaning litter box" : slug.includes("feeder") ? "an automatic pet feeder" : slug.includes("fountain") ? "a pet water fountain" : "a pet camera"}, consider these key factors:</p>
        <ol class="space-y-3 text-bark-muted">
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-forest text-xs font-bold text-white">1</span>
            <span><strong class="text-bark">Number of pets:</strong> Multi-pet homes need {isLitterBox ? "multi-cat recognition features and larger waste drawers" : slug.includes("feeder") ? "larger food hoppers (6L+)" : slug.includes("fountain") ? "larger capacity (3L+)" : "wider coverage and treat capacity"}.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-forest text-xs font-bold text-white">2</span>
            <span><strong class="text-bark">App reliability:</strong> A smart device is only as good as its app. All our top picks have solid app experiences with responsive support teams.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-forest text-xs font-bold text-white">3</span>
            <span><strong class="text-bark">Maintenance cost:</strong> Factor in {isLitterBox ? "replacement liners, trays, or litter costs" : slug.includes("feeder") ? "cleaning and replacement parts" : slug.includes("fountain") ? "replacement filters every 2-4 weeks" : "optional subscription fees for AI features"}.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-forest text-xs font-bold text-white">4</span>
            <span><strong class="text-bark">Noise level:</strong> If the device sits in your living area, quiet operation matters. All our picks operate at acceptable noise levels.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-forest text-xs font-bold text-white">5</span>
            <span><strong class="text-bark">Space & footprint:</strong> Measure your available space — {isLitterBox ? "self-cleaning boxes are larger than traditional litter boxes" : slug.includes("feeder") ? "feeders need stable counter/floor space" : slug.includes("fountain") ? "fountains need stable flat surfaces near outlets" : "cameras need a clear view across the room"}.</span>
          </li>
        </ol>
      </div>
    </section>

    <FAQ items={pageData.faqs} />

    <!-- Bottom CTA -->
    {allProducts[0] && (
      <div class="mt-10 rounded-2xl border border-honey/40 bg-gradient-to-br from-honey/5 to-cream p-6 text-center md:p-8">
        <p class="font-display text-xl font-bold text-forest">Our top pick: {allProducts[0].name}</p>
        <p class="mt-2 text-bark-muted">The best overall choice — check the latest price on Amazon.</p>
        <a href={allProducts[0].amazonUrl} target="_blank" rel="nofollow sponsored noopener"
           class="mt-5 inline-flex items-center gap-2 rounded-xl bg-honey px-8 py-3 font-bold text-white shadow-sm transition-all hover:bg-honey-dark hover:shadow-md active:scale-[0.98]">
          Check Price on Amazon
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <p class="mt-3 text-xs text-bark-muted/70">As an Amazon Associate, we earn from qualifying purchases. <a href="/affiliate-disclosure/" class="underline">Learn more</a></p>
      </div>
    )}
  </article>
</BaseLayout>
