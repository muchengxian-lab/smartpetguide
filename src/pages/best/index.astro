---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

const bestLists = [
  {
    slug: "automatic-cat-feeders",
    title: "5 Best Automatic Cat Feeders 2026",
    desc: "App-controlled, camera-equipped smart feeders compared. WOPET, Petlibro, DOGNESS, and more.",
    count: 5,
  },
  {
    slug: "self-cleaning-litter-boxes",
    title: "6 Best Self-Cleaning Litter Boxes 2026",
    desc: "Litter-Robot 4, Amazon Basics, Leo's Loo Too, PetSafe ScoopFree, and more — compared for odor control, price, and reliability.",
    count: 6,
  },
  {
    slug: "smart-pet-water-fountains",
    title: "5 Best Smart Pet Water Fountains 2026",
    desc: "Filtered, flowing water fountains from PETKIT, Catit, Pioneer Pet, and others to keep your pet hydrated.",
    count: 5,
  },
  {
    slug: "pet-cameras",
    title: "5 Best Pet Cameras 2026",
    desc: "Treat-tossing, 360° pan/tilt, and AI-powered pet cameras. Furbo, Petcube, eufy, and more.",
    count: 5,
  },
  {
    slug: "pet-cameras-no-subscription",
    title: "Best Pet Cameras Without Subscription 2026",
    desc: "No monthly fees, full features: cameras that store locally or offer free cloud access. xpai, eufy, Honey Tour compared.",
    count: 4,
  },
  {
    slug: "gps-trackers-no-monthly-fee",
    title: "Best GPS Dog Trackers Without Monthly Fee 2026",
    desc: "One-time purchase GPS trackers with no subscriptions. Real tracking performance without recurring costs.",
    count: 3,
  },
  {
    slug: "stainless-steel-cat-fountains",
    title: "Best Stainless Steel Cat Water Fountains 2026",
    desc: "Hygienic, durable steel fountains that keep water fresh. YEAPAW, KittySpout, Pioneer Pet — ranked and reviewed.",
    count: 5,
  },
  {
    slug: "automatic-feeders-for-2-cats",
    title: "Best Automatic Feeders for 2 Cats 2026",
    desc: "Stop food theft with multi-cat smart feeders. Portion control, microchip detection, and dual-bowl options.",
    count: 4,
  },
  {
    slug: "litter-boxes-for-large-cats",
    title: "Best Self-Cleaning Litter Boxes for Large Cats 2026",
    desc: "Extra-large entry and spacious interiors for Maine Coons, Ragdolls, and cats over 15 lbs.",
    count: 4,
  },
];
---

<BaseLayout
  title="Best Pet Tech Picks 2026 — SmartPetGuide"
  description="Curated lists of the best automatic pet feeders, self-cleaning litter boxes, smart water fountains, pet cameras, and GPS trackers."
>
  <Breadcrumb crumbs={[{ label: "Best Picks" }]} />

  <article>
    <h1 class="font-display text-3xl font-bold leading-tight text-forest md:text-4xl">Best Picks</h1>
    <p class="mt-3 text-lg leading-relaxed text-bark-muted">
      Curated roundups of the best smart pet devices across every category. Each list is updated for 2026 based on verified owner data and honest analysis.
    </p>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {bestLists.map((list) => (
        <a
          href={`/best/${list.slug}`}
          class="group rounded-2xl border border-sage-dark/30 bg-white p-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
        >
          <p class="font-display text-lg font-semibold text-forest transition-colors group-hover:text-honey">
            {list.title}
          </p>
          <p class="mt-2 text-sm leading-relaxed text-bark-muted">{list.desc}</p>
          <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-forest/60">
            {list.count} products
          </p>
        </a>
      ))}
    </div>
  </article>
</BaseLayout>
