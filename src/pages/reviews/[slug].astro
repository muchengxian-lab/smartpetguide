---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FAQ from "../../components/FAQ.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Takeaways from "../../components/Takeaways.astro";
import products from "../../data/products.json";

// Flat lookup: product ID → product object
const allProducts = new Map<string, any>();
for (const [cat, items] of Object.entries(products)) {
  for (const p of items as any[]) {
    allProducts.set(p.id, p);
  }
}

export function getStaticPaths() {
  return [
    { params: { slug: "litter-robot-4-review" } },
    { params: { slug: "petlibro-granary-review" } },
    { params: { slug: "wopet-automatic-feeder-review" } },
    { params: { slug: "dogness-mini-smart-feeder-review" } },
    { params: { slug: "leos-loo-too-review" } },
    { params: { slug: "petsafe-scoopfree-review" } },
    { params: { slug: "petkit-eversweet-review" } },
    { params: { slug: "catit-pixi-fountain-review" } },
    { params: { slug: "pioneer-pet-raindrop-review" } },
    { params: { slug: "furbo-360-camera-review" } },
    { params: { slug: "petcube-bites-2-review" } },
