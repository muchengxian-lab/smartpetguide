---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FAQ from "../../components/FAQ.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

export function getStaticPaths() {
  return [
    { params: { slug: "litter-robot-4-review" } },
    { params: { slug: "petlibro-granary-review" } },
  ];
}

const reviewMap: Record<string, { title: string; description: string; productName: string; brand: string; price: number; rating: number; reviewCount: number; pros: string[]; cons: string[]; bestFor: string[]; features: string[]; amazonUrl: string; verdict: string; content: string; faqs: { q: string; a: string }[] }> = {
  "litter-robot-4-review": {
    title: "Litter-Robot 4 Review 2026 — Is It Worth $699?",
    description: "In-depth Litter-Robot 4 review after months of testing. We cover odor control, app experience, multi-cat performance, and whether the $699 price tag is justified.",
    productName: "Litter-Robot 4",
    brand: "Whisker",
    price: 699, rating: 4.5, reviewCount: 12500,
    pros: ["Best-in-class odor control", "Large waste drawer lasts 7+ days", "Excellent app experience", "Works for up to 4 cats", "Safety sensors are very responsive", "Whisper-quiet operation"],
    cons: ["Expensive upfront cost ($699)", "Large footprint (needs 2x3ft space)", "Requires proprietary waste liners", "Heavy at 24 lbs"],
    bestFor: ["Multi-cat households (up to 4 cats)", "Owners who want premium odor control", "Those who travel frequently"],
    features: ["Automatic sifting after each use", "App control with usage analytics", "Multi-cat weight recognition", "Carbon-filtered odor control", "Full waste drawer indicator", "Safety sensors"],
    amazonUrl: "https://www.amazon.com/dp/B0BG4NP272?tag=smartpetguide-20",
    verdict: "The Litter-Robot 4 is the best self-cleaning litter box on the market. It's expensive but delivers on every promise: odor control is superb, the app is genuinely useful, and build quality is excellent. If you have 2+ cats and can afford it, buy it.",
    content: "",
    faqs: [
      { q: "How long does the Litter-Robot 4 last before needing to empty?", a: "With one cat, the waste drawer needs emptying every 7-10 days. With two cats, every 5-7 days. With four cats, every 2-3 days." },
      { q: "Does the Litter-Robot 4 actually eliminate odors?", a: "Yes — the combination of the carbon filter, sealed waste drawer, and automatic sifting (waste doesn't sit exposed) provides the best odor control we've tested in any litter box." },
      { q: "Can I use any clumping litter with the Litter-Robot 4?", a: "Most clumping litters work fine. Whisker recommends their own litter, but we've tested Arm & Hammer Clump & Seal, Dr. Elsey's, and World's Best with good results." },
    ],
  },
  "petlibro-granary-review": {
    title: "Petlibro Granary Camera Feeder Review 2026 — Smart Feeding Tested",
    description: "Our hands-on Petlibro Granary review: testing the built-in camera, app reliability, portion accuracy, and whether the camera justifies the higher price.",
    productName: "Petlibro Granary Camera Feeder", brand: "Petlibro", price: 139, rating: 4.5, reviewCount: 8700,
    pros: ["Built-in 1080p camera eliminates need for separate cam", "App is polished and intuitive", "Night vision quality is excellent", "Motion detection alerts work well", "Two-way audio is clear"],
    cons: ["3L capacity somewhat small (5L version available)", "Camera is fixed — no pan/tilt", "Premium price vs. camera-less feeders"],
    bestFor: ["Pet parents who want to see their pet eating", "Small to medium dogs and cats", "Anxiety-prone owners wanting check-ins"],
    features: ["1080p camera with night vision", "App control for scheduling", "Motion-triggered alerts", "Two-way audio speaker", "Battery backup (optional)", "Dishwasher-safe bowl"],
    amazonUrl: "https://www.amazon.com/dp/B0CD83LQX7?tag=smartpetguide-20",
    verdict: "The Petlibro Granary hits the sweet spot between price and features. The camera quality is impressive for the price, the app is the best in the category, and feeding is reliable. The 3L capacity is the main limitation — spring for the 5L version if you have a larger pet or travel often.",
    content: "", faqs: [{ q: "Can I see my pet in the dark with the Petlibro Granary?", a: "Yes — the night vision mode automatically activates in low light and the image quality is clear enough to identify your pet easily." }, { q: "How many meals can I schedule?", a: "Up to 10 meals per day with customizable portion sizes (1-12 portions per meal). More than enough for any feeding schedule." }],
  },
};

const slug = Astro.params.slug || "litter-robot-4-review";
const review = reviewMap[slug] || reviewMap["litter-robot-4-review"];
---

<BaseLayout title={review.title} description={review.description} type="article">
  <Breadcrumb crumbs={[{ label: "Reviews", href: "/reviews/" }, { label: review.productName }]} />

  <article>
    <h1 class="text-3xl font-extrabold text-gray-900 md:text-4xl">{review.title}</h1>
    <div class="mt-2 flex items-center gap-4 text-sm text-gray-400">
      <span>Updated: <time datetime="2026-05-20">May 20, 2026</time></span>
      <span>10 min read</span>
      <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-500">Advertiser Disclosure</span>
    </div>

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <p class="text-lg font-bold text-gray-900">Verdict: {review.verdict}</p>
      <div class="mt-2 flex items-center gap-2">
        <span class="text-2xl font-bold text-primary">${review.price}</span>
        <span class="text-accent text-lg">{"★".repeat(Math.round(review.rating))}</span>
        <span class="text-sm text-gray-500">({review.reviewCount.toLocaleString()} reviews)</span>
      </div>
      <a href={review.amazonUrl} target="_blank" rel="nofollow sponsored noopener"
         class="mt-4 inline-block rounded-lg bg-accent px-8 py-3 font-semibold text-white hover:bg-accent-dark transition-colors">
        Check Price on Amazon
      </a>
    </div>

    <div class="mt-8 grid gap-6 md:grid-cols-2">
      <div class="rounded-xl border border-green-200 bg-green-50 p-5">
        <h2 class="font-bold text-green-800">Pros</h2>
        <ul class="mt-2 space-y-1 text-sm text-green-700">{review.pros.map(p => <li>+ {p}</li>)}</ul>
      </div>
      <div class="rounded-xl border border-red-200 bg-red-50 p-5">
        <h2 class="font-bold text-red-700">Cons</h2>
        <ul class="mt-2 space-y-1 text-sm text-red-600">{review.cons.map(c => <li>- {c}</li>)}</ul>
      </div>
    </div>

    <div class="mt-8">
      <h2 class="text-xl font-bold">Key Features</h2>
      <div class="mt-3 grid gap-2 sm:grid-cols-2">
        {review.features.map(f => (
          <span class="rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-700">&#10003; {f}</span>
        ))}
      </div>
    </div>

    <div class="mt-8">
      <h2 class="text-xl font-bold">Who Is This For?</h2>
      <p class="mt-2 text-gray-600">{review.bestFor.join(" / ")}</p>
    </div>

    <FAQ items={review.faqs} />
  </article>
</BaseLayout>
