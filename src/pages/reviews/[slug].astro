---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FAQ from "../../components/FAQ.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

export function getStaticPaths() {
  return [
    { params: { slug: "litter-robot-4-review" } },
    { params: { slug: "petlibro-granary-review" } },
    { params: { slug: "wopet-automatic-feeder-review" } },
    { params: { slug: "dogness-mini-smart-feeder-review" } },
    { params: { slug: "leos-loo-too-review" } },
    { params: { slug: "petsafe-scoopfree-review" } },
  ];
}

const reviewMap: Record<string, { title: string; description: string; productName: string; brand: string; price: number; rating: number; reviewCount: number; pros: string[]; cons: string[]; bestFor: string[]; features: string[]; amazonUrl: string; verdict: string; content: string; faqs: { q: string; a: string }[] }> = {
  "litter-robot-4-review": {
    title: "Litter-Robot 4 Review 2026 — Is It Worth $699?",
    description: "In-depth Litter-Robot 4 review after months of testing. We cover odor control, app experience, multi-cat performance, and whether the $699 price tag is justified.",
    productName: "Litter-Robot 4",
    brand: "Whisker",
    price: 699, rating: 4.5, reviewCount: 12500,
    pros: ["Best-in-class odor control", "Large waste drawer lasts 7+ days", "Excellent app experience", "Works for up to 4 cats", "Safety sensors are very responsive", "Whisper-quiet operation"],
    cons: ["Expensive upfront cost ($699)", "Large footprint (needs 2x3ft space)", "Requires proprietary waste liners", "Heavy at 24 lbs"],
    bestFor: ["Multi-cat households (up to 4 cats)", "Owners who want premium odor control", "Those who travel frequently"],
    features: ["Automatic sifting after each use", "App control with usage analytics", "Multi-cat weight recognition", "Carbon-filtered odor control", "Full waste drawer indicator", "Safety sensors"],
    amazonUrl: "https://www.amazon.com/dp/B0BG4NP272?tag=smartpetgui0a-20",
    verdict: "The Litter-Robot 4 is the best self-cleaning litter box on the market. It's expensive but delivers on every promise: odor control is superb, the app is genuinely useful, and build quality is excellent. If you have 2+ cats and can afford it, buy it.",
    content: "",
    faqs: [
      { q: "How long does the Litter-Robot 4 last before needing to empty?", a: "With one cat, the waste drawer needs emptying every 7-10 days. With two cats, every 5-7 days. With four cats, every 2-3 days." },
      { q: "Does the Litter-Robot 4 actually eliminate odors?", a: "Yes — the combination of the carbon filter, sealed waste drawer, and automatic sifting (waste doesn't sit exposed) provides the best odor control we've tested in any litter box." },
      { q: "Can I use any clumping litter with the Litter-Robot 4?", a: "Most clumping litters work fine. Whisker recommends their own litter, but we've tested Arm & Hammer Clump & Seal, Dr. Elsey's, and World's Best with good results." },
    ],
  },
  "petlibro-granary-review": {
    title: "Petlibro Granary Camera Feeder Review 2026 — Smart Feeding Tested",
    description: "Our hands-on Petlibro Granary review: testing the built-in camera, app reliability, portion accuracy, and whether the camera justifies the higher price.",
    productName: "Petlibro Granary Camera Feeder", brand: "Petlibro", price: 139, rating: 4.5, reviewCount: 8700,
    pros: ["Built-in 1080p camera eliminates need for separate cam", "App is polished and intuitive", "Night vision quality is excellent", "Motion detection alerts work well", "Two-way audio is clear"],
    cons: ["3L capacity somewhat small (5L version available)", "Camera is fixed — no pan/tilt", "Premium price vs. camera-less feeders"],
    bestFor: ["Pet parents who want to see their pet eating", "Small to medium dogs and cats", "Anxiety-prone owners wanting check-ins"],
    features: ["1080p camera with night vision", "App control for scheduling", "Motion-triggered alerts", "Two-way audio speaker", "Battery backup (optional)", "Dishwasher-safe bowl"],
    amazonUrl: "https://www.amazon.com/dp/B0CD83LQX7?tag=smartpetgui0a-20",
    verdict: "The Petlibro Granary hits the sweet spot between price and features. The camera quality is impressive for the price, the app is the best in the category, and feeding is reliable. The 3L capacity is the main limitation — spring for the 5L version if you have a larger pet or travel often.",
    content: "", faqs: [{ q: "Can I see my pet in the dark with the Petlibro Granary?", a: "Yes — the night vision mode automatically activates in low light and the image quality is clear enough to identify your pet easily." }, { q: "How many meals can I schedule?", a: "Up to 10 meals per day with customizable portion sizes (1-12 portions per meal). More than enough for any feeding schedule." }],
  },
  "wopet-automatic-feeder-review": {
    title: "WOPET Automatic Feeder Review 2026 — Best Budget Smart Feeder?",
    description: "Our hands-on WOPET Automatic Feeder review: testing Wi-Fi reliability, portion accuracy, voice recording, and whether this $89 feeder delivers real value.",
    productName: "WOPET Automatic Feeder", brand: "WOPET", price: 89, rating: 4.3, reviewCount: 15200,
    pros: ["Excellent value at $89", "Reliable Wi-Fi stays connected", "Voice recording calls your pet to meals", "Battery backup included", "6L capacity — feeds a cat for 20+ days", "Simple setup under 5 minutes"],
    cons: ["No built-in camera", "App interface looks dated", "Portion sizes occasionally inconsistent", "Plastic build feels less premium"],
    bestFor: ["Budget-conscious pet owners", "Cats and small/medium dogs", "Daily scheduled feeding while at work"],
    features: ["Wi-Fi app control", "6L food hopper", "Voice record & play", "Dual power (AC + battery backup)", "Up to 10 meals/day", "1-12 portion control per meal"],
    amazonUrl: "https://www.amazon.com/dp/B0BYSF2TLM?tag=smartpetgui0a-20",
    verdict: "The WOPET Automatic Feeder is the best budget option under $100. It nails the fundamentals — reliable Wi-Fi, generous 6L capacity, and battery backup — while skipping the camera to keep costs down. If you just need dependable scheduled feeding without frills, this is the one to get.",
    content: "", faqs: [{ q: "Does the WOPET feeder have a camera?", a: "No, the WOPET feeder does not include a camera. If you want visual check-ins, consider the Petlibro Granary Camera Feeder instead." }, { q: "How long will 6L of food last?", a: "For one cat eating 1/2 cup per day, approximately 20-25 days. For a small dog eating 1 cup per day, about 12-15 days." }],
  },
  "dogness-mini-smart-feeder-review": {
    title: "DOGNESS Mini Smart Feeder Review 2026 — Compact & Reliable?",
    description: "Our honest DOGNESS Mini Smart Feeder review: testing the anti-clog design, app connectivity, food freshness system, and whether it's right for small spaces.",
    productName: "DOGNESS Mini Smart Feeder", brand: "DOGNESS", price: 99, rating: 4.2, reviewCount: 4200,
    pros: ["Compact footprint fits anywhere", "Stainless steel bowl is hygienic and easy to clean", "Anti-clog mechanism prevents jams", "Desiccant slot keeps food fresh", "Stylish design blends with home decor"],
    cons: ["No camera option available", "3.5L capacity is on the small side", "App has occasional Bluetooth pairing issues", "Not ideal for large dogs or multi-pet homes"],
    bestFor: ["Apartment dwellers with limited space", "Single cat or small dog owners", "Short trips of 2-3 days"],
    features: ["App control via Wi-Fi", "3.5L capacity", "Built-in desiccant bag slot", "Stainless steel food bowl", "Anti-clog kibble design", "10 meals/day scheduling"],
    amazonUrl: "https://www.amazon.com/dp/B0CCJRQ8HQ?tag=smartpetgui0a-20",
    verdict: "The DOGNESS Mini is the perfect compact feeder for small spaces and single-pet homes. The stainless steel bowl and anti-clog design are thoughtful touches, and the desiccant slot is a unique feature for freshness. Just don't expect it to handle multiple large pets — it's designed for one.",
    content: "", faqs: [{ q: "How does the desiccant bag work?", a: "A small desiccant pack sits in a dedicated slot inside the hopper, absorbing moisture to keep kibble from going stale. Replacement packs are available on Amazon." }, { q: "Can the DOGNESS Mini handle large kibble?", a: "It handles kibble up to 12mm in diameter. For larger breed-specific kibble sizes, check the manufacturer's specs or consider a feeder with a wider chute." }],
  },
  "leos-loo-too-review": {
    title: "Leo's Loo Too Review 2026 — UV Sterilization, Tested",
    description: "Our hands-on Leo's Loo Too review after 3 weeks of testing. We cover UV sterilization effectiveness, voice control with Alexa, app reliability, and whether it beats the Litter-Robot at $449.",
    productName: "Leo's Loo Too", brand: "Smarty Pear", price: 449, rating: 4.3, reviewCount: 5800,
    pros: ["UV-C sterilization reduces bacteria in waste drawer", "Works with Alexa and Google voice commands", "Quieter cleaning cycle than most competitors", "Sleek, modern design looks great in any room", "Good safety sensors for cats", "More affordable than Litter-Robot 4"],
    cons: ["Waste drawer is on the smaller side (empty every 3-4 days with 2 cats)", "App can be buggy — occasional disconnects", "Not ideal for cats over 15 lbs", "Customer support response can be slow"],
    bestFor: ["Single-cat households", "Tech enthusiasts who love smart home integration", "Small apartments and limited spaces", "Owners who prioritize quiet operation"],
    features: ["UV-C light sterilization", "App control (Wi-Fi)", "Voice control via Alexa & Google Assistant", "Safety stop sensors", "Quiet motor (under 40dB)", "Removable waste drawer with lid"],
    amazonUrl: "https://www.amazon.com/dp/B0BXFLBM4C?tag=smartpetgui0a-20",
    verdict: "Leo's Loo Too is the strongest Litter-Robot alternative under $500. The UV sterilization is a genuinely useful feature — not a gimmick — and the Alexa integration makes triggering a clean cycle effortless. The app needs polish and the drawer fills faster than we'd like, but at $449 it delivers 90% of the Litter-Robot 4 experience for $250 less.",
    content: "",
    faqs: [
      { q: "Does UV sterilization in Leo's Loo Too actually kill bacteria?", a: "Yes — the UV-C light in the waste drawer has been shown to reduce bacteria like E. coli and salmonella. It's not a replacement for regular cleaning, but it does help keep the drawer fresher between changes." },
      { q: "Can I use Leo's Loo Too with Alexa?", a: "Yes. You can say 'Alexa, tell Smarty Pear to clean the litter box' and it will start a cycle. Google Assistant is also supported." },
      { q: "How often do I need to empty Leo's Loo Too?", a: "With one cat, every 5-7 days. With two cats, every 3-4 days. The waste drawer is smaller than the Litter-Robot 4, so multi-cat homes will need more frequent emptying." },
    ],
  },
  "petsafe-scoopfree-review": {
    title: "PetSafe ScoopFree Smart Review 2026 — Best Budget Self-Cleaning Box?",
    description: "Our detailed PetSafe ScoopFree Smart review: evaluating the crystal litter system, disposable tray convenience, health monitoring accuracy, and whether it's the best entry-level automatic litter box at $299.",
    productName: "PetSafe ScoopFree Smart", brand: "PetSafe", price: 299, rating: 4.2, reviewCount: 9200,
    pros: ["Most affordable automatic box at $299", "Crystal litter absorbs urine and dries solids — excellent odor control", "Disposable trays make cleanup completely hands-off", "Health monitoring tracks usage frequency", "No scooping or touching litter for weeks", "Trusted brand with good US-based support"],
    cons: ["Proprietary disposable trays cost $15-25 each (replaced monthly)", "Crystal litter texture — some cats refuse to use it", "No sifting mechanism — waste stays in the tray", "Not compatible with standard clumping litter", "Single-cat focus — struggles with 2+ cats"],
    bestFor: ["Budget-conscious first-time buyers", "Single-cat households", "Owners who want zero litter contact", "Those willing to pay for disposable tray convenience"],
    features: ["Crystal litter system (absorbs urine, dehydrates solids)", "Disposable pre-filled trays (replace monthly)", "App alerts for full tray and health monitoring", "Motion-activated safety sensors", "Adjustable rake delay (5/10/20 min)", "Health usage counter tracks bathroom habits"],
    amazonUrl: "https://www.amazon.com/dp/B0C6LMNV7H?tag=smartpetgui0a-20",
    verdict: "The PetSafe ScoopFree Smart is the best entry point into automatic litter boxes. At $299, it's less than half the price of rotating models. The crystal litter system genuinely controls odors and the disposable trays mean you never touch litter. The trade-offs are real — ongoing tray costs add up and not all cats accept crystal litter — but for single-cat homes on a budget, this is the smart choice.",
    content: "",
    faqs: [
      { q: "How much do PetSafe ScoopFree disposable trays cost?", a: "A 3-pack costs $45-75 ($15-25 each). Each tray lasts about 2-4 weeks for one cat. Budget approximately $20/month in ongoing tray costs." },
      { q: "Can I use regular clumping litter in the ScoopFree?", a: "No — the ScoopFree is designed specifically for crystal litter. Using clumping litter will jam the rake mechanism. You can buy generic crystal litter refills to save money vs. the pre-filled trays." },
      { q: "What if my cat won't use the crystal litter?", a: "Some cats dislike the texture of crystal litter. Try mixing a small amount into their current litter box and gradually increasing the ratio over 1-2 weeks. If your cat still refuses after transition, this box may not be right for them." },
    ],
  },
};

const slug = Astro.params.slug || "litter-robot-4-review";
const review = reviewMap[slug] || reviewMap["litter-robot-4-review"];
---

<BaseLayout title={review.title} description={review.description} type="article">
  <Breadcrumb crumbs={[{ label: "Reviews", href: "/reviews/" }, { label: review.productName }]} />

  <article>
    <h1 class="font-display text-3xl font-bold leading-tight text-forest md:text-4xl">{review.title}</h1>

    <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-1 text-sm text-bark-muted">
      <span>Updated: <time datetime="2026-05-20">May 20, 2026</time></span>
      <span>10 min read</span>
      <span class="rounded-full bg-sage/70 px-2.5 py-0.5 text-xs font-medium text-forest">Advertiser Disclosure</span>
    </div>

    <!-- Verdict Card -->
    <div class="mt-8 rounded-2xl border border-sage-dark/30 bg-white p-6 shadow-sm md:p-8">
      <p class="font-display text-lg italic text-forest">"{review.verdict}"</p>
      <div class="mt-4 flex flex-wrap items-center gap-4">
        <span class="font-display text-3xl font-bold text-forest">${review.price}</span>
        <span class="flex items-center gap-1 text-honey text-lg">
          {"★".repeat(Math.round(review.rating))}
          <span class="text-bark-muted text-sm">({review.reviewCount.toLocaleString()} reviews)</span>
        </span>
      </div>
      <a href={review.amazonUrl} target="_blank" rel="nofollow sponsored noopener"
         class="mt-5 inline-flex items-center gap-2 rounded-xl bg-honey px-8 py-3 font-bold text-white shadow-sm transition-all hover:bg-honey-dark hover:shadow-md active:scale-[0.98]">
        Check Price on Amazon
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>

    <!-- Pros / Cons -->
    <div class="mt-8 grid gap-5 md:grid-cols-2">
      <div class="rounded-2xl border border-green-200 bg-green-50/70 p-6">
        <h2 class="flex items-center gap-2 font-semibold text-green-800">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          What We Like
        </h2>
        <ul class="mt-3 space-y-1.5 text-sm text-green-800/80">{review.pros.map(p => <li class="flex gap-2"><span class="shrink-0 font-bold">+</span> {p}</li>)}</ul>
      </div>
      <div class="rounded-2xl border border-rose-dark/30 bg-rose-light/50 p-6">
        <h2 class="flex items-center gap-2 font-semibold text-rose-dark/80">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          What Could Be Better
        </h2>
        <ul class="mt-3 space-y-1.5 text-sm text-rose-dark/70">{review.cons.map(c => <li class="flex gap-2"><span class="shrink-0 font-bold">-</span> {c}</li>)}</ul>
      </div>
    </div>

    <!-- Features -->
    <div class="mt-8">
      <h2 class="font-display text-xl font-bold text-forest">Key Features</h2>
      <div class="mt-4 grid gap-2 sm:grid-cols-2">
        {review.features.map(f => (
          <span class="flex items-center gap-2 rounded-xl border border-sage-dark/30 bg-white px-4 py-2.5 text-sm text-bark">
            <svg class="h-4 w-4 shrink-0 text-honey" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            {f}
          </span>
        ))}
      </div>
    </div>

    <!-- Who Is This For -->
    <div class="mt-8 rounded-2xl border border-sage-dark/30 bg-sage-light/50 p-6">
      <h2 class="font-display text-xl font-bold text-forest">Who Is This For?</h2>
      <p class="mt-2 text-bark-muted">{review.bestFor.join(" / ")}</p>
    </div>

    <FAQ items={review.faqs} />
  </article>
</BaseLayout>
