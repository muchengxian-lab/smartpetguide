  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Review",
    url: Astro.url.href,
    itemReviewed: {
      "@type": "Product",
      name: product?.name || review.title,
      description: review.description,
      image: product?.imageUrl || "",
      brand: { "@type": "Brand", name: product?.brand || "" },
      offers: { "@type": "Offer", price: String(product?.price || 0), priceCurrency: "USD", availability: "https://schema.org/InStock", url: product?.amazonUrl || "" },
      ...(product?.rating && product?.reviewCount >= 10 ? {
        aggregateRating: { "@type": "AggregateRating", ratingValue: product.rating, bestRating: 5, ratingCount: product.reviewCount }
      } : {}),
    },
    ...(product?.rating && product?.reviewCount >= 10 ? {
      reviewRating: { "@type": "Rating", ratingValue: product.rating, bestRating: 5 }
    } : {}),
    author: { "@type": "Person", name: "Chengxian Yang", url: "https://smartpetguide.net/about/#author", sameAs: ["https://medium.com/@muchengxian", "https://www.pinterest.com/muchengxian/", "https://www.wikidata.org/wiki/Q140290653"] },
    datePublished: pubDate,
