---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

const breedPages = [
  {
    slug: "best-feeder-for-french-bulldog",
    title: "Best Smart Devices for French Bulldogs",
    desc: "Flat-faced breeds have unique needs: slow feeders, cooling mats, GPS trackers — smart tech picks for Frenchies.",
  },
  {
    slug: "best-devices-for-golden-retrievers",
    title: "Best Smart Devices for Golden Retrievers",
    desc: "Large, active, food-motivated: the best feeders, cameras, and trackers for America's favorite family dog.",
  },
  {
    slug: "best-devices-for-labrador-retrievers",
    title: "Best Smart Devices for Labrador Retrievers",
    desc: "Built for labs: heavy-duty feeders, waterproof GPS trackers, and durable pet cameras for this energetic breed.",
  },
  {
    slug: "best-devices-for-german-shepherds",
    title: "Best Smart Devices for German Shepherds",
    desc: "Intelligent and protective: smart tech picks for GSDs including GPS trackers, large-capacity feeders, and training cameras.",
  },
  {
    slug: "best-devices-for-multiple-cats",
    title: "Best Smart Devices for Multiple Cats",
    desc: "Multi-cat households need multi-cat solutions: self-cleaning boxes, microchip feeders, and fountains that serve everyone.",
  },
  {
    slug: "best-devices-for-senior-cats",
    title: "Best Smart Devices for Senior Cats",
    desc: "Aging cats need easier access, health monitoring, and comfort: smart devices tailored for senior feline care.",
  },
  {
    slug: "best-devices-for-small-dogs",
    title: "Best Smart Devices for Small Dogs",
    desc: "Tiny dogs, big tech: small-portion feeders, lightweight GPS trackers, and compact cameras for breeds under 20 lbs.",
  },
];
---

<BaseLayout
  title="Smart Pet Devices by Breed 2026 — Tailored Recommendations | SmartPetGuide"
  description="Breed-specific smart pet device recommendations: French Bulldog, Golden Retriever, Labrador, German Shepherd, Multiple Cats, Senior Cats, and Small Dogs."
>
  <Breadcrumb crumbs={[{ label: "Breed Guides" }]} />

  <article>
    <h1 class="font-display text-3xl font-bold leading-tight text-forest md:text-4xl">Breed Guides</h1>
    <p class="mt-3 text-lg leading-relaxed text-bark-muted">
      Every breed is different. We pick the right smart devices for your specific pet — size, temperament, and special needs considered.
    </p>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {breedPages.map((b) => (
        <a
          href={`/breed/${b.slug}`}
          class="group rounded-2xl border border-sage-dark/30 bg-white p-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
        >
          <p class="font-display text-lg font-semibold text-forest transition-colors group-hover:text-honey">
            {b.title}
          </p>
          <p class="mt-2 text-sm leading-relaxed text-bark-muted">{b.desc}</p>
        </a>
      ))}
    </div>
  </article>
</BaseLayout>
