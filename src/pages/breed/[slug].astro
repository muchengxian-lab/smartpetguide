---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FAQ from "../../components/FAQ.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import products from "../../data/products.json";

// Flat lookup: product ID → product object
const allProducts = new Map<string, any>();
for (const [, items] of Object.entries(products)) {
  for (const p of items as any[]) {
    allProducts.set(p.id, p);
  }
}

export function getStaticPaths() {
  return [
    { params: { slug: "best-feeder-for-french-bulldog" } },
  ];
}

interface Recommendation {
  category: string;
  productId: string;
  reason: string;
}

interface BreedData {
  title: string;
  description: string;
  breed: string;
  recommendations: Recommendation[];
  tips: string[];
  faqs: { q: string; a: string }[];
}

const breedMap: Record<string, BreedData> = {
  "best-feeder-for-french-bulldog": {
    title: "Best Automatic Feeder for French Bulldogs in 2026 — Top Picks",
    description: "French Bulldogs have unique feeding needs — flat faces, tendency to overeat, and sensitive digestion. We've picked the best feeders that work for your Frenchie.",
    breed: "French Bulldog",
    recommendations: [
      { category: "Best Overall", productId: "petlibro-granary", reason: "Camera lets you monitor your Frenchie's eating, and the portion control prevents overeating — critical for this obesity-prone breed." },
      { category: "Best Budget", productId: "wopet-automatic", reason: "6L capacity and reliable scheduling at an affordable price. Voice recording is great for calling your Frenchie to meals." },
      { category: "Best for Portion Control", productId: "petkit-fresh-element", reason: "Excellent portion accuracy and food freshness system. The app tracks every meal — perfect for weight-managing Frenchies." },
    ],
    tips: ["Frenchies are prone to bloat — use a slow-feed bowl insert even with automatic feeders", "Elevate the feeder slightly to reduce neck strain", "Divide daily food into 3-4 smaller meals rather than 1-2 large ones", "Monitor weight monthly — Frenchies gain weight easily"],
    faqs: [
      { q: "Do French Bulldogs need a special automatic feeder?", a: "Not a special feeder, but you do need one with precise portion control. Frenchies are prone to obesity, so accurate portioning is more important than for other breeds." },
      { q: "Should I elevate my Frenchie's feeder?", a: "Slightly elevating the feeder (4-6 inches) can make eating more comfortable for flat-faced breeds. Some feeders have built-in stands or you can use a separate elevated platform." },
    ],
  },
};

const slug = Astro.params.slug || "best-feeder-for-french-bulldog";
const data = breedMap[slug] || breedMap["best-feeder-for-french-bulldog"];
---

<BaseLayout title={data.title} description={data.description} type="article">
  <Breadcrumb crumbs={[{ label: "Breed-Specific", href: "/breed/" }, { label: data.breed }]} />

  <article>
    <h1 class="font-display text-3xl font-bold leading-tight text-forest md:text-4xl">{data.title}</h1>
    <p class="mt-3 text-lg leading-relaxed text-bark-muted">{data.description}</p>

    <!-- Recommendations -->
    <section class="mt-10">
      <h2 class="mb-5 font-display text-2xl font-bold text-forest">Our Picks for {data.breed}s</h2>
      <div class="grid gap-4">
        {data.recommendations.map((rec) => {
          const product = allProducts.get(rec.productId);
          return (
            <div class="rounded-2xl border border-sage-dark/30 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
              <span class="inline-block rounded-full bg-forest/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-forest">{rec.category}</span>
              <h3 class="mt-2 font-display text-lg font-semibold text-forest">{product?.name || rec.productId}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-bark-muted">{rec.reason}</p>
              <a href={product?.amazonUrl || "#"} target="_blank" rel="nofollow sponsored noopener"
                 class="mt-4 inline-flex items-center gap-1.5 rounded-xl bg-honey px-5 py-2.5 text-sm font-bold text-white shadow-sm transition-all hover:bg-honey-dark hover:shadow-md active:scale-[0.98]">
                Check Price
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Tips -->
    <section class="mt-10 rounded-2xl border border-sage-dark/30 bg-sage-light/50 p-6 md:p-8">
      <h2 class="font-display text-xl font-bold text-forest">{data.breed}-Specific Feeding Tips</h2>
      <ul class="mt-4 space-y-2.5">
        {data.tips.map((tip) => (
          <li class="flex gap-3 text-bark-muted">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-honey"></span>
            {tip}
          </li>
        ))}
      </ul>
    </section>

    <FAQ items={data.faqs} />
  </article>
</BaseLayout>
