<BaseLayout
  title="Smart Pet Device Buying Guides 2026 | SmartPetGuide"
  description="Comprehensive buying guides for automatic feeders, self-cleaning litter boxes, smart water fountains, and pet cameras. Make an informed choice."
>
  <Breadcrumb crumbs={[{ label: "Guides" }]} />

  <article>
    <h1 class="font-display text-3xl font-bold leading-tight text-forest md:text-4xl">Buying Guides</h1>
    <p class="mt-3 text-lg leading-relaxed text-bark-muted">
      Not sure where to start? Our comprehensive buying guides walk you through every feature, spec, and trade-off so you can choose with confidence.
    </p>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {guides.map((g) => (
        <a
          href={`/guides/${g.slug}`}
          class="group rounded-2xl border border-sage-dark/30 bg-white p-6 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
        >
          <div class="mb-3 inline-flex items-center gap-1.5 rounded-full bg-honey/10 px-3 py-1 text-xs font-semibold text-honey">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            {g.sections} sections
          </div>
          <p class="font-display text-lg font-semibold text-forest transition-colors group-hover:text-honey">
            {g.title}
          </p>
          <p class="mt-2 text-sm leading-relaxed text-bark-muted">{g.desc}</p>
        </a>
      ))}
    </div>
  </article>
</BaseLayout>
