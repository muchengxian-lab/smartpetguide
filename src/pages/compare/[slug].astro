const data = compareMap[slug] || compareMap["litter-robot-4-vs-leos-loo-too"];

// Get products from products.json, or use inline data for generic comparisons
const productA = data.productAId ? allProducts.get(data.productAId) : data.productA;
const productB = data.productBId ? allProducts.get(data.productBId) : data.productB;

import datesRaw from "../../data/content-dates.json";
const dates = datesRaw as any;
const compareDates = dates.pages?.compare?.[slug];
if (!compareDates) throw new Error(`Missing content date registry entry: compare/${slug}`);
const pubDate = compareDates.publishDate;
const modDate = compareDates.modifiedDate;
const displayMod = new Date(modDate + "T12:00:00").toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<BaseLayout title={data.title} description={data.description} type="article" publishDate={pubDate} modifiedDate={modDate}>
  <Breadcrumb crumbs={[{ label: "Compare", href: "/compare/" }, { label: productA.name + " vs " + productB.name }]} />

  <article>
    <h1 class="font-display text-3xl font-bold leading-tight text-forest md:text-4xl">{data.title}</h1>
    <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-1 text-sm text-bark-muted">
      <span>Updated: <time datetime={modDate}>{displayMod}</time></span>
    </div>
    <p class="mt-3 text-lg leading-relaxed text-bark-muted">{data.description}</p>

    <!-- Trust line -->
    <p class="mt-3 text-sm text-bark-muted/80 italic">How we compare: We analyze verified owner reviews and product specs — <a href="/about/" class="underline decoration-honey/50 hover:text-honey">learn more about our research process</a></p>

    <Takeaways items={[
      `Winner: ${data.winner.substring(0, 100)}...`,
      `${productA.name} — $${productA.price} | ${productA.rating}★`,
      `${productB.name} — ${typeof productB.price === 'number' ? '$' + productB.price : productB.price} | ${productB.rating}★`,
      `${data.comparisonRows.length} features compared head-to-head`,
    ]} />

    <!-- Bottom Line -->
    <div class="mt-8 rounded-2xl border border-honey/30 bg-honey/5 p-6 md:p-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-honey">Bottom Line</p>
      <p class="mt-2 font-display text-lg italic text-forest">"{data.winner}"</p>
    </div>

    <!-- Side by Side Cards -->
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {[productA, productB].map((p, idx) => (
        <div class={`rounded-2xl border p-6 ${idx === 0 ? 'border-forest/20 bg-forest/3' : 'border-sage-dark/30 bg-white'}`}>
          <!-- Product image -->
          {p.imageUrl && (
            <img src={p.imageUrl} alt={p.name} class="mb-4 h-48 w-full rounded-xl object-cover bg-sage/60" width="400" height="192" loading="lazy" decoding="async" />
          )}
          {p.reviewSlug ? <h2 class="font-display text-xl font-bold text-forest"><a href={`/reviews/${p.reviewSlug}/`} class="hover:text-honey transition-colors">{p.name}</a></h2> : <h2 class="font-display text-xl font-bold text-forest">{p.name}</h2>}
          <p class="text-sm text-bark-muted">by {p.brand}</p>
          <p class="mt-2 font-display text-3xl font-bold text-forest">{typeof p.price === 'number' ? '$' + p.price : p.price}</p>
          {typeof p.price === 'number' && <p class="text-sm text-bark-muted">~${Math.round(p.price / 36)}/mo over 3 years</p>}
          <div class="mt-4 space-y-2.5 text-sm">
            <p class="font-semibold text-green-800">Pros</p>
            {p.pros.map((pro: string) => <p class="text-green-800/80">&check; {pro}</p>)}
            <p class="mt-2 font-semibold text-rose-dark/80">Cons</p>
            {p.cons.map((con: string) => <p class="text-rose-dark/70">&times; {con}</p>)}
          </div>
          <a href={p.amazonUrl} target="_blank" rel="nofollow sponsored noopener"
             class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-honey py-3 font-bold text-white shadow-sm transition-all hover:bg-honey-dark hover:shadow-md active:scale-[0.98]">
            View on Amazon
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Data Snapshot -->
    <div class="mt-10 rounded-2xl border border-sage-dark/30 bg-cream/50 p-5">
      <p class="text-sm font-bold uppercase tracking-wide text-bark-muted">Data Snapshot</p>
      <p class="mt-1 text-sm leading-relaxed text-bark-muted">Prices and ratings as of July 2026. Comparison based on manufacturer specifications, verified Amazon owner reviews, and marketplace data. Individual experiences may vary.</p>
    </div>

    <!-- Feature Comparison Table -->
    <div class="mt-6">
      <h2 class="mb-4 font-display text-xl font-bold text-forest">Feature Comparison</h2>
      <div class="overflow-x-auto rounded-2xl border border-sage-dark/30">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-sage/60">
              <th class="px-5 py-3.5 text-left font-semibold text-forest">Feature</th>
              <th class="px-5 py-3.5 font-semibold text-forest">{productA.name}</th>
              <th class="px-5 py-3.5 font-semibold text-forest">{productB.name}</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-sage-dark/20">
            {data.comparisonRows.map(([feature, a, b]) => (
              <tr class="bg-white transition-colors hover:bg-sage-light/50">
                <td class="px-5 py-3.5 font-medium text-bark">{feature}</td>
                <td class="px-5 py-3.5 text-bark-muted">{a}</td>
                <td class="px-5 py-3.5 text-bark-muted">{b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    {/* Quick Decision Module */}
    {data.buyIf && data.skipIf && data.bestAlternative && (
      <div class="mt-10 rounded-2xl border border-forest/20 bg-gradient-to-br from-forest/5 to-sage/20 p-6 md:p-8">
        <h2 class="font-display text-xl font-bold text-forest">Quick Decision: Which One Should You Buy?</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-3">
          <div class="rounded-xl border border-green-200/50 bg-green-50/50 p-4">
            <p class="text-sm font-bold text-green-800">✅ Buy Petlibro if</p>
            <p class="mt-1 text-sm leading-relaxed text-green-900/80">{data.buyIf}</p>
          </div>
          <div class="rounded-xl border border-red-200/50 bg-red-50/50 p-4">
            <p class="text-sm font-bold text-red-800">❌ Skip if</p>
            <p class="mt-1 text-sm leading-relaxed text-red-900/80">{data.skipIf}</p>
          </div>
          <div class="rounded-xl border border-honey/30 bg-honey/5 p-4">
            <p class="text-sm font-bold text-forest">🔄 Best alternative</p>
            <p class="mt-1 text-sm leading-relaxed text-bark" set:html={data.bestAlternative} />
          </div>
        </div>
      </div>
    )}

    {/* What Owners Say */}
    {data.whatOwnersSay && (
      <div class="mt-10 rounded-2xl border border-sage-dark/30 bg-cream/50 p-6">
        <h2 class="font-display text-xl font-bold text-forest">What Owners Say</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          <div class="rounded-xl border border-green-200/50 bg-green-50/50 p-4">
            <p class="text-sm font-bold text-green-800">Most Common Praise</p>
            <p class="mt-2 text-sm leading-relaxed text-green-900/80" set:html={data.whatOwnersSay.praise} />
          </div>
          <div class="rounded-xl border border-red-200/50 bg-red-50/50 p-4">
            <p class="text-sm font-bold text-red-800">Most Common Complaints</p>
            <p class="mt-2 text-sm leading-relaxed text-red-900/80" set:html={data.whatOwnersSay.complaints} />
          </div>
        </div>
      </div>
    )}

    <FAQ items={data.faqs} />

    <!-- Bottom CTA -->
    <div class="mt-10 rounded-2xl border border-honey/40 bg-gradient-to-br from-honey/5 to-cream p-6 md:p-8">
      <p class="font-display text-xl font-bold text-forest text-center">Which one is right for you?</p>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {[productA, productB].map((p) => (
          <a href={p?.amazonUrl || "#"} target="_blank" rel="nofollow sponsored noopener"
             class="flex flex-col items-center rounded-xl border border-sage-dark/30 bg-white p-5 shadow-sm transition-all hover:border-honey/50 hover:shadow-md active:scale-[0.98]">
            <span class="font-semibold text-forest">{p?.name || "Product"}</span>
            <span class="text-sm text-bark-muted">by {p?.brand || ""}</span>
            {p?.price && <span class="mt-1 font-bold text-honey">${p.price}</span>}
            <span class="mt-3 inline-flex items-center gap-1.5 rounded-lg bg-honey px-5 py-2 text-sm font-bold text-white">View on Amazon <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></span>
          </a>
        ))}
      </div>
      <p class="mt-4 text-center text-xs text-bark-muted/70">As an Amazon Associate, we earn from qualifying purchases. <a href="/affiliate-disclosure/" class="underline">Learn more</a></p>
    </div>

    <p class="mt-8 text-xs text-bark-muted/70 border-t border-sage-dark/20 pt-4">Written by <a href="/about/#author" class="underline decoration-sage-dark/50 underline-offset-2">Chengxian Yang</a>. Data sourced from Amazon.com verified purchase reviews, manufacturer specifications, and product listings as of July 2026. Prices and ratings reflect current marketplace data at time of research. Individual experiences may vary.</p>
  </article>
</BaseLayout>
