---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FAQ from "../../components/FAQ.astro";
import Takeaways from "../../components/Takeaways.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import products from "../../data/products.json";

// Flat lookup: product ID → product object
const allProducts = new Map<string, any>();
for (const [cat, items] of Object.entries(products)) {
  for (const p of items as any[]) {
    allProducts.set(p.id, p);
  }
}

export function getStaticPaths() {
  return [
    { params: { slug: "litter-robot-4-vs-leos-loo-too" } },
    { params: { slug: "automatic-vs-manual-litter-box" } },
    { params: { slug: "wopet-vs-petlibro" } },
    { params: { slug: "furbo-vs-petcube" } },
    { params: { slug: "litter-robot-4-vs-petsafe-scoopfree" } },
    { params: { slug: "furbo-vs-eufy" } },
    { params: { slug: "pioneer-pet-vs-yeapaw" } },
    { params: { slug: "xpai-vs-eufy" } },
    { params: { slug: "petkit-eversweet-vs-catit-pixi" } },
  ];
}

const slug = Astro.params.slug || "litter-robot-4-vs-leos-loo-too";

interface CompareData {
  title: string;
  description: string;
  productAId?: string;
  productBId?: string;
  productA?: any;
  productB?: any;
  winner: string;
  comparisonRows: string[][];
  faqs: { q: string; a: string }[];
}

const compareMap: Record<string, CompareData> = {
  "litter-robot-4-vs-leos-loo-too": {
    title: "Litter-Robot 4 vs Leo's Loo Too (2026) — Which Self-Cleaning Box Wins?",
    description: "Head-to-head comparison: Litter-Robot 4 vs Leo's Loo Too. We compare price, odor control, features, app quality, and cat comfort to help you decide.",
    winner: "The Litter-Robot 4 edges out the Leo's Loo Too on overall quality, odor control, and app polish — but at $250 more. For most buyers, Leo's Loo Too is the smarter value with UV sterilization and voice control built in.",
    productAId: "litter-robot-4",
    productBId: "leos-loo-too",
    comparisonRows: [
      ["Price", "$699", "$449"],
      ["Rating", "★★★★½", "★★★★⅓"],
      ["App Control", "Yes", "Yes"],
      ["Multi-Cat", "Up to 4", "Up to 2"],
      ["UV Sterilization", "No", "Yes"],
      ["Voice Control", "No", "Yes (Alexa/Google)"],
      ["Warranty", "1 year", "1 year"],
