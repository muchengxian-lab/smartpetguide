{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/sitemap.xml", "destination": "/sitemap-index.xml", "permanent": true },
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.smartpetguide.net" }], "destination": "https://smartpetguide.net/:path*", "permanent": true }
  ]
}
